@page "/contacto"
@inject LamillaEscudero.Application.Abstractions.IConfiguracionEstudioService ConfigService
@inject LamillaEscudero.Application.Abstractions.IConsultaWebService ConsultaService
@rendermode InteractiveServer

<PageTitle>Contacto — Lamilla Escudero</PageTitle>

<section class="cx-section">
    <div class="container">

        @* ── Encabezado de sección ── *@
        <div class="cx-hero">
            <span class="cx-eyebrow">Estamos para ayudarte</span>
            <h1 class="cx-hero-title">Inicie su consulta <span class="cx-title-accent">hoy</span></h1>
            <p class="cx-hero-sub">
                Cuéntenos su situación y un especialista del estudio
                se pondrá en contacto con usted en el menor tiempo posible.
            </p>
        </div>

        <div class="row gx-5 gy-5 align-items-stretch">

            @* ═══════════════════════════════
                 COL IZQ — FORMULARIO PREMIUM
                 ═══════════════════════════════ *@
            <div class="col-lg-6 d-flex flex-column">

                @if (!string.IsNullOrWhiteSpace(mensaje))
                {
                    <div class="cx-success">
                        <div class="cx-success-ring">
                            <i class="bi bi-check2"></i>
                        </div>
                        <div class="cx-success-copy">
                            <p class="cx-success-title">¡Consulta recibida!</p>
                            <p class="cx-success-sub">@mensaje</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="cx-form-shell flex-grow-1">

                        @* Decorativo: línea lateral dorada *@
                        <div class="cx-form-accent-bar"></div>

                        <div class="cx-form-inner">
                            <div class="cx-form-header">
                                <div class="cx-form-icon"><i class="bi bi-pen-fill"></i></div>
                                <div>
                                    <p class="cx-form-label-top">FORMULARIO DE CONSULTA</p>
                                    <p class="cx-form-desc">Todos los campos marcados con * son obligatorios.</p>
                                </div>
                            </div>

                            <EditForm Model="form" OnValidSubmit="Enviar">
                                <DataAnnotationsValidator />
                                <ValidationSummary class="cx-validation-summary" />

                                <div class="row g-4">

                                    <div class="col-md-6">
                                        <div class="cx-field">
                                            <label class="cx-label">Nombre completo <span class="cx-required">*</span></label>
                                            <div class="cx-input-wrap">
                                                <i class="bi bi-person cx-input-icon"></i>
                                                <InputText class="cx-input" @bind-Value="form.Nombre" placeholder="Su nombre completo" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="cx-field">
                                            <label class="cx-label">Correo electrónico</label>
                                            <div class="cx-input-wrap">
                                                <i class="bi bi-envelope cx-input-icon"></i>
                                                <InputText class="cx-input" @bind-Value="form.Email" placeholder="correo@ejemplo.com" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="cx-field">
                                            <label class="cx-label">Teléfono</label>
                                            <div class="cx-input-wrap">
                                                <i class="bi bi-telephone cx-input-icon"></i>
                                                <InputText class="cx-input" @bind-Value="form.Telefono" placeholder="+593 9..." />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="cx-field">
                                            <label class="cx-label">Asunto <span class="cx-required">*</span></label>
                                            <div class="cx-input-wrap">
                                                <i class="bi bi-tag cx-input-icon"></i>
                                                <InputText class="cx-input" @bind-Value="form.Asunto" placeholder="Motivo de consulta" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="cx-field">
                                            <label class="cx-label">Mensaje <span class="cx-required">*</span></label>
                                            <div class="cx-textarea-wrap">
                                                <InputTextArea class="cx-textarea" rows="5"
                                                               @bind-Value="form.Mensaje"
                                                               placeholder="Describa brevemente su situación o necesidad legal..." />
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                @* CTA + Aviso de privacidad *@
                                <div class="cx-cta-row">
                                    <button class="cx-btn-submit" type="submit" disabled="@enviando">
                                        @if (enviando)
                                        {
                                            <span class="cx-spinner"></span>
                                            <span>Enviando...</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-send-fill"></i>
                                            <span>Enviar consulta</span>
                                            <i class="bi bi-arrow-right cx-btn-arrow"></i>
                                        }
                                    </button>

                                    <p class="cx-privacy-note">
                                        <i class="bi bi-shield-check"></i>
                                        Sus datos son tratados con absoluta confidencialidad.
                                    </p>
                                </div>

                            </EditForm>
                        </div>
                    </div>
                }
            </div>

            @* ═══════════════════════════════
                 COL DER — TARJETA DE INFORMACIÓN
                 ═══════════════════════════════ *@
            <div class="col-lg-6 d-flex flex-column">
                <div class="cx-info-card flex-grow-1">

                    @* Orbe decorativo *@
                    <div class="cx-orb cx-orb-1"></div>
                    <div class="cx-orb cx-orb-2"></div>

                    <div class="cx-info-inner">

                        @if (config is not null)
                        {
                            <div class="cx-info-brand">
                                <div class="cx-info-mono">LE</div>
                                <div>
                                    <div class="cx-info-firm">@config.NombreEstudio</div>
                                    @if (!string.IsNullOrWhiteSpace(config.Slogan))
                                    {
                                        <div class="cx-info-slogan">@config.Slogan</div>
                                    }
                                </div>
                            </div>

                            <div class="cx-info-sep"></div>
                        }

                        <p class="cx-info-section-label">INFORMACIÓN DE CONTACTO</p>

                        <div class="cx-info-items">

                            @if (!string.IsNullOrWhiteSpace(config?.TelefonoContacto))
                            {
                                var numero = System.Text.RegularExpressions.Regex.Replace(config.TelefonoContacto, @"\D", "");
                                var mensajeWp = Uri.EscapeDataString("Hola Abogado Lamilla, me comunico desde su página web para solicitar una consulta...");
                                <a class="cx-info-item cx-info-link"
                                   href="https://wa.me/@numero?text=@mensajeWp"
                                   target="_blank" rel="noopener">
                                    <div class="cx-info-item-icon cx-icon-green">
                                        <i class="bi bi-whatsapp"></i>
                                    </div>
                                    <div class="cx-info-item-body">
                                        <span class="cx-info-item-label">WhatsApp / Teléfono</span>
                                        <span class="cx-info-item-value">
                                            @config.TelefonoContacto
                                            <i class="bi bi-box-arrow-up-right cx-ext-icon"></i>
                                        </span>
                                    </div>
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(config?.EmailContacto))
                            {
                                var asunto = Uri.EscapeDataString("Consulta desde la página web");
                                var cuerpo = Uri.EscapeDataString("Estimado Abogado,\n\nMe comunico para solicitar información sobre sus servicios legales.\n\nQuedo a la espera de su respuesta.\n\nAtentamente,");
                                <a class="cx-info-item cx-info-link"
                                   href="mailto:@config.EmailContacto?subject=@asunto&body=@cuerpo">
                                    <div class="cx-info-item-icon cx-icon-gold">
                                        <i class="bi bi-envelope-fill"></i>
                                    </div>
                                    <div class="cx-info-item-body">
                                        <span class="cx-info-item-label">Correo electrónico</span>
                                        <span class="cx-info-item-value">
                                            @config.EmailContacto
                                            <i class="bi bi-box-arrow-up-right cx-ext-icon"></i>
                                        </span>
                                    </div>
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(config?.Direccion))
                            {
                                <div class="cx-info-item">
                                    <div class="cx-info-item-icon cx-icon-blue">
                                        <i class="bi bi-geo-alt-fill"></i>
                                    </div>
                                    <div class="cx-info-item-body">
                                        <span class="cx-info-item-label">Dirección</span>
                                        <span class="cx-info-item-value">@config.Direccion</span>
                                    </div>
                                </div>
                            }

                        </div>

                        @if (urlMapa is not null)
                        {
                            <div class="cx-map-wrap">
                                <iframe src="@urlMapa"
                                        width="100%" height="250"
                                        style="border:0; display:block;"
                                        allowfullscreen loading="lazy"
                                        referrerpolicy="no-referrer-when-downgrade">
                                </iframe>
                                @if (config?.MapLatitude.HasValue == true)
                                {
                                    <a class="cx-map-link"
                                       href="https://www.openstreetmap.org/?mlat=@config.MapLatitude&mlon=@config.MapLongitude#map=16/@config.MapLatitude/@config.MapLongitude"
                                       target="_blank" rel="noopener">
                                        <i class="bi bi-box-arrow-up-right me-1"></i>
                                        Ver mapa completo
                                    </a>
                                }
                            </div>
                        }

                        @* Sello de confianza *@
                        <div class="cx-trust-badges">
                            <div class="cx-trust-item">
                                <i class="bi bi-shield-lock-fill"></i>
                                <span>Confidencialidad garantizada</span>
                            </div>
                            <div class="cx-trust-item">
                                <i class="bi bi-clock-fill"></i>
                                <span>Respuesta en 24 h</span>
                            </div>
                            <div class="cx-trust-item">
                                <i class="bi bi-award-fill"></i>
                                <span>Asesoría especializada</span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    /* ═══════════════════════════════════════════════════
           CONTACTO — Premium UI  (Lamilla Escudero)
           Adaptado 100% a las variables dinámicas de la aplicación
           ═══════════════════════════════════════════════════ */

    .cx-section {
        padding: 5rem 0 6rem;
        background: var(--ivory);
    }

    /* ── Hero ───────────────────────────────────────── */
    .cx-hero {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .cx-eyebrow {
        display: inline-block;
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: var(--gold);
        background: rgba(184, 150, 62, 0.1); /* Efecto gold-pale dinámico */
        padding: .35rem 1rem;
        border-radius: 100px;
        margin-bottom: 1rem;
    }

    .cx-hero-title {
        font-family: var(--font-display, 'Georgia', serif);
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 700;
        color: var(--navy);
        margin: 0 0 .75rem;
        line-height: 1.1;
    }

    .cx-title-accent {
        color: var(--gold);
        font-style: italic;
    }

    .cx-hero-sub {
        max-width: 500px;
        margin: 0 auto;
        font-size: .95rem;
        color: var(--silver);
        line-height: 1.7;
    }

    /* ── Formulario — contenedor glass ─────────────── */
    .cx-form-shell {
        position: relative;
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1px solid var(--light-gray);
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    /* barra lateral dorada */
    .cx-form-accent-bar {
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: linear-gradient(180deg, var(--gold) 0%, var(--gold-light) 100%);
    }

    .cx-form-inner {
        padding: 2.25rem 2.25rem 2.25rem 2.75rem;
    }

    .cx-form-header {
        display: flex;
        align-items: center;
        gap: .875rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--light-gray);
    }

    .cx-form-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-sm);
        background: var(--navy);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold-light);
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .cx-form-label-top {
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .12em;
        color: var(--gold);
        margin: 0 0 .15rem;
    }

    .cx-form-desc {
        font-size: .78rem;
        color: var(--silver);
        margin: 0;
    }

    /* ── Labels ─────────────────────────────────────── */
    .cx-label {
        display: block;
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--navy);
        margin-bottom: .5rem;
    }

    .cx-required {
        color: var(--gold);
        margin-left: 2px;
    }

    /* ── Inputs con icono ───────────────────────────── */
    .cx-field {
        display: flex;
        flex-direction: column;
    }

    .cx-input-wrap {
        position: relative;
    }

    .cx-input-icon {
        position: absolute;
        left: .875rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--silver);
        font-size: .9rem;
        pointer-events: none;
        transition: color var(--transition);
    }

    .cx-input,
    .cx-textarea {
        width: 100%;
        background: var(--ivory);
        border: 1.5px solid var(--light-gray);
        border-radius: var(--radius-sm);
        font-family: inherit;
        font-size: .9rem;
        color: var(--charcoal);
        transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
        outline: none;
    }

    .cx-input {
        padding: .75rem .875rem .75rem 2.625rem;
    }

    .cx-textarea {
        padding: .875rem 1rem;
        resize: vertical;
        min-height: 130px;
    }

        .cx-input::placeholder,
        .cx-textarea::placeholder {
            color: var(--silver);
            opacity: 0.7;
        }

        /* Foco — borde + sombra dorada */
        .cx-input:focus,
        .cx-textarea:focus {
            border-color: var(--gold);
            background: var(--white);
            box-shadow: 0 0 0 4px rgba(184, 150, 62, 0.25);
        }

    .cx-input-wrap:focus-within .cx-input-icon {
        color: var(--gold);
    }

    .cx-textarea-wrap {
        position: relative;
    }

    /* ── Validación ─────────────────────────────────── */
    .cx-validation-summary {
        background: #FEF2F2;
        border: 1px solid #FECACA;
        color: #991B1B;
        border-radius: var(--radius-sm);
        padding: .75rem 1rem;
        font-size: .82rem;
        margin-bottom: 1.25rem;
    }

    /* ── CTA ────────────────────────────────────────── */
    .cx-cta-row {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-top: 1.75rem;
        flex-wrap: wrap;
    }

    .cx-btn-submit {
        display: inline-flex;
        align-items: center;
        gap: .625rem;
        padding: .875rem 2rem;
        border: none;
        border-radius: var(--radius-sm);
        background: linear-gradient(135deg, var(--navy) 0%, rgba(11,31,58, 0.85) 100%);
        color: var(--white);
        font-size: .9rem;
        font-weight: 600;
        letter-spacing: .02em;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
        box-shadow: var(--shadow-sm);
    }

        .cx-btn-submit::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            opacity: 0;
            transition: opacity var(--transition);
        }

        .cx-btn-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

            .cx-btn-submit:hover:not(:disabled)::before {
                opacity: 1;
            }

        .cx-btn-submit > * {
            position: relative;
            z-index: 1;
        }

        .cx-btn-submit:active:not(:disabled) {
            transform: translateY(0);
        }

        .cx-btn-submit:disabled {
            opacity: .6;
            cursor: not-allowed;
        }

    .cx-btn-arrow {
        transition: transform var(--transition);
    }

    .cx-btn-submit:hover:not(:disabled) .cx-btn-arrow {
        transform: translateX(4px);
    }

    /* Spinner inline */
    .cx-spinner {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: cx-spin .65s linear infinite;
    }

    @@keyframes cx-spin {
        to

    {
        transform: rotate(360deg);
    }

    }

    .cx-privacy-note {
        font-size: .76rem;
        color: var(--silver);
        margin: 0;
        display: flex;
        align-items: center;
        gap: .375rem;
    }

    /* ── Éxito ──────────────────────────────────────── */
    .cx-success {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border: 1px solid #86EFAC;
        border-radius: var(--radius-lg);
        padding: 2rem;
        animation: cx-fadein .4s ease;
    }

    @@keyframes cx-fadein {
        from

    {
        opacity: 0;
        transform: translateY(8px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .cx-success-ring {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #16A34A;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
        box-shadow: 0 0 0 6px rgba(22,163,74,.15);
    }

    .cx-success-title {
        font-family: var(--font-display, 'Georgia', serif);
        font-size: 1.3rem;
        font-weight: 700;
        color: #14532D;
        margin: 0 0 .4rem;
    }

    .cx-success-sub {
        font-size: .875rem;
        color: #166534;
        margin: 0;
        line-height: 1.55;
    }

    /* ── Tarjeta de información (derecha) ───────────── */
    .cx-info-card {
        position: relative;
        background: var(--navy);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    /* Orbes decorativos */
    .cx-orb {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }

    .cx-orb-1 {
        width: 320px;
        height: 320px;
        top: -100px;
        right: -100px;
        background: radial-gradient(circle, rgba(255,255,255,.05) 0%, transparent 70%);
    }

    .cx-orb-2 {
        width: 220px;
        height: 220px;
        bottom: -60px;
        left: -60px;
        background: radial-gradient(circle, rgba(255,255,255,.03) 0%, transparent 70%);
    }

    .cx-info-inner {
        position: relative;
        z-index: 1;
        padding: 2.25rem;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    /* Marca */
    .cx-info-brand {
        display: flex;
        align-items: center;
        gap: .875rem;
        margin-bottom: 1.5rem;
    }

    .cx-info-mono {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-sm);
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display, 'Georgia', serif);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--gold-light);
        flex-shrink: 0;
    }

    .cx-info-firm {
        font-family: var(--font-display, 'Georgia', serif);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--white);
        line-height: 1.2;
    }

    .cx-info-slogan {
        font-size: .78rem;
        color: rgba(255,255,255,.5);
        font-style: italic;
        margin-top: .2rem;
    }

    .cx-info-sep {
        height: 1px;
        background: rgba(255,255,255,.08);
        margin-bottom: 1.5rem;
    }

    .cx-info-section-label {
        font-size: .63rem;
        font-weight: 700;
        letter-spacing: .14em;
        color: var(--gold);
        margin: 0 0 1rem;
    }

    /* Items de contacto */
    .cx-info-items {
        display: flex;
        flex-direction: column;
        gap: .75rem;
        margin-bottom: 1.5rem;
    }

    .cx-info-item {
        display: flex;
        align-items: center;
        gap: .875rem;
        padding: .875rem 1rem;
        border-radius: var(--radius-sm);
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.06);
        transition: background var(--transition), border-color var(--transition);
        text-decoration: none;
        color: inherit;
    }

    .cx-info-link:hover {
        background: rgba(255,255,255,.08);
        border-color: rgba(255,255,255,.15);
    }

    .cx-info-item-icon {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        flex-shrink: 0;
    }

    .cx-icon-green {
        background: rgba(34,197,94,.15);
        color: #4ade80;
    }

    .cx-icon-gold {
        background: rgba(255,255,255,.1);
        color: var(--gold-light);
    }

    .cx-icon-blue {
        background: rgba(96,165,250,.15);
        color: #93c5fd;
    }

    .cx-info-item-body {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .cx-info-item-label {
        font-size: .65rem;
        font-weight: 600;
        letter-spacing: .09em;
        text-transform: uppercase;
        color: rgba(255,255,255,.38);
    }

    .cx-info-item-value {
        font-size: .875rem;
        color: rgba(255,255,255,.85);
        margin-top: .15rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cx-ext-icon {
        font-size: .62rem;
        opacity: .5;
        margin-left: .3rem;
    }

    /* Mapa */
    .cx-map-wrap {
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.1);
        margin-bottom: 1.5rem;
    }

    .cx-map-link {
        display: block;
        text-align: center;
        font-size: .75rem;
        color: rgba(255,255,255,.4);
        padding: .5rem;
        text-decoration: none;
        background: rgba(0,0,0,.2);
