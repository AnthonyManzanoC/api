@page "/acceso-denegado"
<PageTitle>Acceso Restringido — Lamilla Escudero</PageTitle>

<div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background-color: var(--ivory);">
    <div class="text-center p-5 bg-white shadow-sm rounded-4" style="max-width: 450px; border-top: 4px solid var(--gold);">
        <i class="bi bi-shield-lock-fill" style="font-size: 4rem; color: var(--navy);"></i>
        <h2 class="mt-4 mb-3" style="font-family: var(--font-display); color: var(--navy);">Acceso Restringido</h2>
        <p class="text-muted mb-4">
            Tu cuenta no tiene los permisos necesarios para visualizar esta área del sistema.
        </p>
        <a href="/" class="btn-primary-gold px-4 py-2" style="text-decoration:none;">
            <i class="bi bi-arrow-left me-2"></i>Volver al inicio
        </a>
    </div>
</div>