@page "/login"
@* ═══════════════════════════════════════════════════════════════
   Login.razor — SIN @rendermode (SSR puro)
   La ausencia de rendermode es la clave: permite que SignInManager
   escriba la cookie de autenticación sin conflicto con el circuito
   SignalR. El antiforgery se inyecta vía [CascadingParameter].
   ═══════════════════════════════════════════════════════════════ *@
@using Microsoft.AspNetCore.Identity
@using LamillaEscudero.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<PageTitle>Acceso — Lamilla Escudero</PageTitle>

<div class="login-page">

    @* ── Panel de marca ─────────────────────────────────── *@
    <aside class="login-brand-panel">
        <div class="login-brand-content">
            <div class="login-brand-emblem">
                <span class="brand-monogram">LE</span>
            </div>
            <h1 class="login-brand-name">Lamilla Escudero</h1>
            <p class="login-brand-tagline">&amp; Asociados</p>
            <div class="login-brand-divider"></div>
            <blockquote class="login-brand-quote">
                «La justicia es la verdad en acción.»
            </blockquote>
            <p class="login-brand-author">— Benjamin Disraeli</p>
        </div>
        <div class="login-brand-footer">
            <a href="/" class="login-brand-back">
                <i class="bi bi-arrow-left me-2"></i>Volver al sitio
            </a>
        </div>
    </aside>

    @* ── Panel del formulario ─────────────────────────── *@
    <main class="login-form-panel">
        <div class="login-form-container">

            <div class="login-form-header">
                <h2 class="login-title">Acceso Interno</h2>
                <p class="login-subtitle">Ingresa tus credenciales para continuar</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="login-alert" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@error
                </div>
            }

            @* ✅ FORMULARIO HTML NATIVO — SSR post — con AntiforgeryToken de Blazor *@
            <form method="post" @formname="login-form" novalidate>
                <AntiforgeryToken />

                <div class="login-field-group">
                    <label class="login-label" for="email">Correo electrónico</label>
                    <div class="login-input-wrapper">
                        <i class="bi bi-envelope login-input-icon"></i>
                        <input id="email"
                               name="Input.Email"
                               type="email"
                               class="login-input @(showEmailError ? "is-invalid" : "")"
                               value="@Input.Email"
                               placeholder="admin@lamillaescudero.com"
                               autocomplete="email" />
                    </div>
                    @if (showEmailError)
                    {
                        <span class="login-validation">El correo es obligatorio.</span>
                    }
                </div>

                <div class="login-field-group">
                    <label class="login-label" for="password">Contraseña</label>
                    <div class="login-input-wrapper">
                        <i class="bi bi-lock login-input-icon"></i>
                        <input id="password"
                               name="Input.Password"
                               type="password"
                               class="login-input @(showPassError ? "is-invalid" : "")"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                    </div>
                    @if (showPassError)
                    {
                        <span class="login-validation">La contraseña es obligatoria.</span>
                    }
                </div>

                <button class="login-btn" type="submit">
                    <span>Ingresar al panel</span>
                    <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </form>

            <p class="login-form-note">
                <i class="bi bi-shield-lock me-1"></i>
                Acceso restringido al personal autorizado.
            </p>
        </div>
    </main>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "login-form")]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? error;
    private bool showEmailError;
    private bool showPassError;

    protected override async Task OnInitializedAsync()
    {
        // Si ya está logueado, redirigir según su rol
        if (HttpContext.User.Identity?.IsAuthenticated == true)
        {
            var destino = HttpContext.User.IsInRole("Cliente") ? "/mi-portal" : "/admin";
            HttpContext.Response.Redirect(destino);
            return;
        }

        if (HttpContext.Request.Method != "POST") return;

        await ProcessLoginAsync();
    }

    private async Task ProcessLoginAsync()
    {
        error = null;
        showEmailError = string.IsNullOrWhiteSpace(Input.Email);
        showPassError = string.IsNullOrWhiteSpace(Input.Password);
        if (showEmailError || showPassError) return;

        var user = await UserManager.FindByEmailAsync(Input.Email!);

        if (user is null || !user.IsActive)
        {
            error = "Credenciales inválidas o cuenta inactiva.";
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(
            Input.Email!, Input.Password!, isPersistent: true, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            // ✅ MAGIA: Leer el rol para saber a dónde enviarlo
            var roles = await UserManager.GetRolesAsync(user);
            var destino = roles.Contains("Cliente") ? "/mi-portal" : "/admin";

            // Si venía de un link específico, respetar ese link
            if (!string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl != "/")
                destino = ReturnUrl;

            HttpContext.Response.Redirect(destino);
            return;
        }

        error = result.IsLockedOut
            ? "Cuenta bloqueada. Intenta en unos minutos."
            : "Contraseña incorrecta.";
    }

    private sealed class InputModel
    {
        public string? Email { get; set; }
        public string? Password { get; set; }
    }
}