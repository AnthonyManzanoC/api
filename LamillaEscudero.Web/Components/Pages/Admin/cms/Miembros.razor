@code {
    /* ── modelos JSON ─────────────────────────────────────────────── */
    private class EducacionItem
    {
        public string Titulo { get; set; } = string.Empty;
        public string Institucion { get; set; } = string.Empty;
        public string Anio { get; set; } = string.Empty;
    }
    private class TimelineItem
    {
        public string Anio { get; set; } = string.Empty;
        public string Titulo { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
    }

    /* ── estado ───────────────────────────────────────────────────── */
    private List<LamillaEscudero.Application.Models.Miembros.MiembroEstudioResponse> miembros = new();
    private LamillaEscudero.Application.Models.Miembros.MiembroEstudioCreateRequest form = new();
    private Guid? editId;
    private string? msg;
    private string? globalMsg;
    private string? fotoError;
    private bool isError;
    private bool saving;
    private bool showForm;
    private string drawerTab = "basico";

    private List<EducacionItem> educacionItems = new();
    private List<TimelineItem> timelineItems = new();

    private static readonly JsonSerializerOptions JsonOpts = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    /* ── ciclo de vida ────────────────────────────────────────────── */
    protected override async Task OnInitializedAsync()
        => miembros = await MiembroService.GetAllAsync();

    /* ── acciones principales ─────────────────────────────────────── */
    private void NuevoMiembro()
    {
        editId = null; form = new(); msg = null; fotoError = null;
        educacionItems = new(); timelineItems = new();
        drawerTab = "basico"; showForm = true;
    }

    private void Editar(LamillaEscudero.Application.Models.Miembros.MiembroEstudioResponse m)
    {
        editId = m.Id;
        form = new()
        {
            Nombres = m.Nombres,
            Cargo = m.Cargo,
            BiografiaBreve = m.BiografiaBreve,
            BiografiaCompleta = m.BiografiaCompleta,
            FotoUrl = m.FotoUrl,
            PhotoData = m.PhotoData,
            FraseDestacada = m.FraseDestacada,
            BiografiaLarga = m.BiografiaLarga,
            EducacionJson = m.EducacionJson,
            TimelineExperienciaJson = m.TimelineExperienciaJson,
            LinkedIn = m.LinkedIn,
            Email = m.Email,
            Orden = m.Orden
        };
        educacionItems = DeserializeList<EducacionItem>(m.EducacionJson);
        timelineItems = DeserializeList<TimelineItem>(m.TimelineExperienciaJson);
        msg = null; fotoError = null;
        drawerTab = "basico"; showForm = true;
    }

    private void CerrarDrawer() { showForm = false; msg = null; }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.Nombres) || string.IsNullOrWhiteSpace(form.Cargo))
        {
            msg = "Nombres y Cargo son obligatorios."; isError = true; return;
        }

        // Serializa listas a JSON
        form.EducacionJson = educacionItems.Any()
            ? JsonSerializer.Serialize(educacionItems, JsonOpts) : null;
        form.TimelineExperienciaJson = timelineItems.Any()
            ? JsonSerializer.Serialize(timelineItems, JsonOpts) : null;

        saving = true;
        try
        {
            if (editId is null)
            {
                await MiembroService.CreateAsync(form);
            }
            else
            {
                await MiembroService.UpdateAsync(editId.Value,
                    new LamillaEscudero.Application.Models.Miembros.MiembroEstudioUpdateRequest
                    {
                        Nombres = form.Nombres,
                        Cargo = form.Cargo,
                        BiografiaBreve = form.BiografiaBreve,
                        BiografiaCompleta = form.BiografiaCompleta,
                        FotoUrl = form.FotoUrl,
                        PhotoData = form.PhotoData,
                        FraseDestacada = form.FraseDestacada,
                        BiografiaLarga = form.BiografiaLarga,
                        EducacionJson = form.EducacionJson,
                        TimelineExperienciaJson = form.TimelineExperienciaJson,
                        LinkedIn = form.LinkedIn,
                        Email = form.Email,
                        Orden = form.Orden,
                        IsActive = true
                    });
            }
            globalMsg = $"'{form.Nombres}' guardado correctamente.";
            miembros = await MiembroService.GetAllAsync();
            CerrarDrawer();
        }
        finally { saving = false; }
    }

    private async Task Eliminar(Guid id)
    {
        await MiembroService.DeleteAsync(id);
        miembros = await MiembroService.GetAllAsync();
    }

    /* ── foto ─────────────────────────────────────────────────────── */
    private async Task CargarFoto(InputFileChangeEventArgs e)
    {
        fotoError = null;
        var file = e.File;
        var allowed = new[] { "image/jpeg", "image/png" };

        if (!allowed.Contains(file.ContentType))
        {
            fotoError = "Solo se permiten archivos JPG o PNG."; return;
        }
        if (file.Size > 2 * 1024 * 1024)
        {
            fotoError = "El archivo supera los 2 MB."; return;
        }

        using var ms = new System.IO.MemoryStream();
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        form.PhotoData = $"data:{file.ContentType};base64,{base64}";
        form.FotoUrl = null; // la foto local tiene prioridad
    }

    private void QuitarFoto() { form.PhotoData = null; form.FotoUrl = null; }

    /* ── listas dinámicas ─────────────────────────────────────────── */
    private void AddEducacion() => educacionItems.Add(new EducacionItem());
    private void RemoveEducacion(int i) => educacionItems.RemoveAt(i);
    private void AddTimeline() => timelineItems.Add(new TimelineItem());
    private void RemoveTimeline(int i) => timelineItems.RemoveAt(i);

    /* ── helpers ──────────────────────────────────────────────────── */
    private static List<T> DeserializeList<T>(string? json) where T : new()
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try { return JsonSerializer.Deserialize<List<T>>(json, JsonOpts) ?? new(); }
        catch { return new(); }
    }

    private static string GetInit(string nombre)
    {
        var p = (nombre ?? "?").Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length >= 2 ? $"{p[0][0]}{p[1][0]}" : p.Length > 0 ? $"{p[0][0]}" : "?";
    }
}
