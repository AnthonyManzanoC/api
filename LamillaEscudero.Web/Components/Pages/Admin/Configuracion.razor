        border: 1px solid rgba(184,150,62,.25);
        color: #7a5c1a;
        font-size: .85rem;
        border-radius: 8px;
    }

    .cfg-footer {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
