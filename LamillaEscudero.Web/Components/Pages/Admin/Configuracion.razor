    }

    .cfg-save-msg {
        font-size: .875rem;
        font-weight: 500;
    }

    .cfg-save-ok {
        color: #16A34A;
    }

    .cfg-save-err {
        color: #DC2626;
    }

    .text-gold {
        color: var(--gold, #B8963E);
    }

    @@media (max-width: 576px) {
        .cfg-photo-area

    {
        grid-template-columns: 1fr;
    }

    .cfg-photo-preview {
        width: 100%;
        height: 140px;
    }

    }
</style>

@code {
    private LamillaEscudero.Application.Models.Configuracion.ConfiguracionEstudioResponse? config;
    private LamillaEscudero.Application.Models.Configuracion.ConfiguracionEstudioUpdateRequest form = new();
    private string activeTab = "estudio";

    // Feedback
    private bool guardando;
    private string? message;
    private bool saveOk;

    // Foto
    private bool cargandoFoto;
    private string? fotoError;

    // SMTP test
    private string? emailPrueba;
    private bool enviandoPrueba;
    private string? mensajePrueba;
    private bool pruebOk;
    private bool mostrarPass;

    protected override async Task OnInitializedAsync()
    {
        config = await ConfigService.GetAsync();
        CargarForm(config);
    }

    private void CargarForm(LamillaEscudero.Application.Models.Configuracion.ConfiguracionEstudioResponse c)
    {
        form = new LamillaEscudero.Application.Models.Configuracion.ConfiguracionEstudioUpdateRequest
        {
            NombreEstudio = c.NombreEstudio,
            Slogan = c.Slogan,
            LogoUrl = c.LogoUrl,
            PhotoUrl = c.PhotoUrl,
            ColorPrimario = c.ColorPrimario,
            ColorSecundario = c.ColorSecundario,
            ColorFondo = c.ColorFondo,
            EmailContacto = c.EmailContacto,
            TelefonoContacto = c.TelefonoContacto,
            Direccion = c.Direccion,
            IsActive = c.IsActive,
            SmtpServer = c.SmtpServer,
            SmtpPort = c.SmtpPort,
            SmtpUser = c.SmtpUser,
            SmtpPass = c.SmtpPass,
            SmtpEnableSsl = c.SmtpEnableSsl,
            SmtpFromName = c.SmtpFromName,
            MapLatitude = c.MapLatitude,
            MapLongitude = c.MapLongitude,
            MapEmbedUrl = c.MapEmbedUrl
        };
    }

    // ── Carga de imagen → Base64 ──────────────────────────────────
    private async Task CargarImagen(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        fotoError = null;
        cargandoFoto = true;

        var file = e.File;

        // Validar tipo
        var tiposPermitidos = new[] { "image/jpeg", "image/png", "image/webp" };
        if (!tiposPermitidos.Contains(file.ContentType))
        {
            fotoError = "Solo se permiten imágenes JPG, PNG o WebP.";
            cargandoFoto = false;
            return;
        }

        // Validar tamaño (2 MB)
        const long maxBytes = 2 * 1024 * 1024;
        if (file.Size > maxBytes)
        {
            fotoError = $"La imagen supera el límite de 2 MB ({file.Size / 1024 / 1024:F1} MB).";
            cargandoFoto = false;
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            form.PhotoUrl = $"data:{file.ContentType};base64,{base64}";
        }
        catch (Exception ex)
        {
            fotoError = $"Error al procesar la imagen: {ex.Message}";
        }
        finally
        {
            cargandoFoto = false;
        }
    }

    private void QuitarFoto() => form.PhotoUrl = null;

    // ── Guardar ───────────────────────────────────────────────────
    private async Task Guardar()
    {
        if (config is null) return;
        guardando = true;
        message = null;

        var ok = await ConfigService.UpdateAsync(config.Id, form);
        if (ok)
        {
            config = await ConfigService.GetAsync();
            message = "Configuración guardada correctamente.";
            saveOk = true;
        }
        else
        {
            message = "No se pudo guardar. Intente nuevamente.";
            saveOk = false;
        }
        guardando = false;

        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            message = null;
            InvokeAsync(StateHasChanged);
        });
    }

    // ── Prueba SMTP ───────────────────────────────────────────────
    private async Task EnviarPrueba()
    {
        if (string.IsNullOrWhiteSpace(emailPrueba)) return;
        await Guardar();  // Guardar primero para que el servicio lea datos actuales

        enviandoPrueba = true;
        mensajePrueba = null;

        var ok = await EmailService.EnviarAsync(
            emailPrueba,
            "Prueba de conexión SMTP — Lamilla Escudero",
            "<p>¡Conexión SMTP funcionando correctamente! 🎉</p>");

        pruebOk = ok;
        mensajePrueba = ok
            ? $"✅ Correo de prueba enviado a {emailPrueba}."
            : "❌ No se pudo enviar. Verifica las credenciales SMTP.";
        enviandoPrueba = false;
    }

    // ── URL mapa ──────────────────────────────────────────────────
    private string ObtenerUrlMapa()
    {
        if (!string.IsNullOrWhiteSpace(form.MapEmbedUrl)) return form.MapEmbedUrl;
        var lat = form.MapLatitude?.ToString("F6",
                      System.Globalization.CultureInfo.InvariantCulture) ?? "0";
        var lon = form.MapLongitude?.ToString("F6",
                      System.Globalization.CultureInfo.InvariantCulture) ?? "0";
        return $"https://www.openstreetmap.org/export/embed.html" +
               $"?bbox={lon}&layer=mapnik&marker={lat}%2C{lon}";
    }
}