@code {
    // ── Estado general ────────────────────────────────────────
    private List<ClienteResponse> clientes = new();
    private ClienteCreateRequest form = new();
    private Guid? editingId;
    private string? message;

    // ── Estado del overlay de honorarios ──────────────────────
    private bool overlayVisible = false;
    private ClienteResponse? clienteOverlay = null;
    private List<AbonoResponse> abonos = new();
    private bool cargandoAbonos = false;

    // ── Fijar honorario ───────────────────────────────────────
    private decimal nuevoHonorario;
    private bool guardandoHonorario = false;
    private string? msgHonorario;
    private bool errorHonorario;

    // ── Nuevo abono ───────────────────────────────────────────
    private AbonoCreateRequest abonoForm = new();
    private DateTime fechaAbonoLocal = DateTime.Today;
    private bool guardandoAbono = false;
    private string? msgAbono;
    private bool errorAbono;

    // ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
        => clientes = await ClienteService.GetAllAsync();

    // ── CRUD de cliente ───────────────────────────────────────

    private async Task Guardar()
    {
        if (editingId is null)
        {
            await ClienteService.CreateAsync(form);
            message = "Cliente creado correctamente.";
        }
        else
        {
            var upd = new ClienteUpdateRequest
            {
                Nombres = form.Nombres,
                Cedula = form.Cedula,
                Email = form.Email,
                Telefono = form.Telefono,
                Direccion = form.Direccion,
                Observaciones = form.Observaciones,
                IsActive = true
            };
            await ClienteService.UpdateAsync(editingId.Value, upd);
            message = "Cliente actualizado correctamente.";
        }
        await Cargar();
        Limpiar();
    }

    private void Editar(ClienteResponse c)
    {
        editingId = c.Id;
        form = new ClienteCreateRequest
        {
            Nombres = c.Nombres,
            Cedula = c.Cedula,
            Email = c.Email,
            Telefono = c.Telefono,
            Direccion = c.Direccion,
            Observaciones = c.Observaciones
        };
    }

    private async Task Eliminar(Guid id)
    {
        await ClienteService.DeleteAsync(id);
        await Cargar();
        message = "Cliente eliminado.";
    }

    private void Limpiar()
    {
        editingId = null;
        form = new ClienteCreateRequest();
    }

    // ── Overlay de honorarios ─────────────────────────────────

    private async Task AbrirOverlay(ClienteResponse c)
    {
        clienteOverlay = c;
        nuevoHonorario = c.TotalHonorarios;
        msgHonorario = null;
        msgAbono = null;
        abonoForm = new AbonoCreateRequest { ClienteId = c.Id, FechaAbono = DateTime.UtcNow };
        fechaAbonoLocal = DateTime.Today;
        overlayVisible = true;
        await CargarAbonos();
    }

    private void CerrarOverlay()
    {
        overlayVisible = false;
        clienteOverlay = null;
        abonos.Clear();
    }

    private async Task CargarAbonos()
    {
        if (clienteOverlay is null) return;
        cargandoAbonos = true;
        abonos = await ClienteService.GetAbonosByClienteAsync(clienteOverlay.Id);
        cargandoAbonos = false;
    }

    // ── Fijar honorario ───────────────────────────────────────

    private async Task FijarHonorario()
    {
        if (clienteOverlay is null) return;
        if (nuevoHonorario < 0) { msgHonorario = "El monto no puede ser negativo."; errorHonorario = true; return; }

        guardandoHonorario = true;
        var ok = await ClienteService.UpdateHonorariosAsync(clienteOverlay.Id, nuevoHonorario);
        guardandoHonorario = false;

        if (ok)
        {
            msgHonorario = "Honorario actualizado correctamente.";
            errorHonorario = false;
            // Refresca el overlay y la lista
            await Cargar();
            clienteOverlay = clientes.FirstOrDefault(x => x.Id == clienteOverlay.Id) ?? clienteOverlay;
            clienteOverlay = await ClienteService.GetByIdAsync(clienteOverlay.Id) ?? clienteOverlay;
        }
        else
        {
            msgHonorario = "Error al actualizar el honorario.";
            errorHonorario = true;
        }
    }

    // ── Registrar abono ───────────────────────────────────────

    private async Task RegistrarAbono()
    {
        if (clienteOverlay is null) return;

        if (abonoForm.Monto <= 0)
        {
            msgAbono = "El monto debe ser mayor a cero.";
            errorAbono = true;
            return;
        }

        // Convertir fecha local a UTC
        abonoForm.ClienteId = clienteOverlay.Id;
        abonoForm.FechaAbono = DateTime.SpecifyKind(fechaAbonoLocal, DateTimeKind.Utc);

        guardandoAbono = true;
        try
        {
            await ClienteService.AddAbonoAsync(abonoForm);
            msgAbono = $"Abono de ${abonoForm.Monto:N2} registrado.";
            errorAbono = false;

            // Limpiar formulario
            abonoForm = new AbonoCreateRequest { ClienteId = clienteOverlay.Id };
            fechaAbonoLocal = DateTime.Today;

            // Refrescar datos
            await CargarAbonos();
            clienteOverlay = await ClienteService.GetByIdAsync(clienteOverlay.Id) ?? clienteOverlay;
            await Cargar();
        }
        catch (Exception ex)
        {
            msgAbono = $"Error: {ex.Message}";
            errorAbono = true;
        }
        finally
        {
            guardandoAbono = false;
        }
    }

    // ── Eliminar abono ────────────────────────────────────────

    private async Task EliminarAbono(Guid abonoId)
    {
        if (clienteOverlay is null) return;

        await ClienteService.DeleteAbonoAsync(abonoId);
        await CargarAbonos();
        clienteOverlay = await ClienteService.GetByIdAsync(clienteOverlay.Id) ?? clienteOverlay;
        await Cargar();
        msgAbono = "Abono eliminado.";
        errorAbono = false;
    }
}
