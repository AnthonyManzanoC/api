@page "/mi-portal"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Cliente")]
@rendermode InteractiveServer
@using System.Security.Claims
@inject LamillaEscudero.Application.Abstractions.IClienteService ClienteService
@inject LamillaEscudero.Application.Abstractions.ICausaService CausaService
@inject LamillaEscudero.Application.Abstractions.IEventoProcesalService EventoService
@inject LamillaEscudero.Application.Abstractions.IPlazoService PlazoService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Mi Portal — Lamilla Escudero</PageTitle>

@if (cargando)
{
    <div class="mp-loading-screen">
        <div class="mp-spinner-ring"></div>
        <span class="mp-loading-text">Cargando tu expediente…</span>
    </div>
}
else if (cliente is null)
{
    <div class="mp-not-linked">
        <div class="mp-not-linked-icon">
            <i class="bi bi-exclamation-circle"></i>
        </div>
        <h2 class="mp-not-linked-title">Cuenta sin perfil vinculado</h2>
        <p class="mp-not-linked-body">
            Tu cuenta de acceso no está asociada a un expediente de cliente.<br />
            Por favor contacta al estudio para resolver esto.
        </p>
        <a href="/" class="mp-btn-primary">
            <i class="bi bi-house-door me-2"></i>Volver al inicio
        </a>
    </div>
}
else
{
    <!-- ══ HERO ════════════════════════════════════════════════════ -->
    <div class="mp-hero">
        <div class="mp-hero-noise"></div>
        <div class="mp-hero-ring mp-hero-ring-1"></div>
        <div class="mp-hero-ring mp-hero-ring-2"></div>

        <div class="container mp-hero-inner">
            <!-- Identidad + logout -->
            <div class="mp-hero-top">
                <div>
                    <span class="mp-eyebrow">Área Privada</span>
                    <h1 class="mp-welcome">Bienvenido/a, <em>@cliente.Nombres.Split(' ')[0]</em></h1>
                    <p class="mp-subwelcome">Seguimiento en tiempo real de tus causas y expedientes legales.</p>
                </div>
                <form method="post" action="/logout" class="mp-logout-form">
                    <AntiforgeryToken />
                    <button type="submit" class="mp-logout-btn">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Cerrar sesión</span>
                    </button>
                </form>
            </div>

            <!-- KPIs -->
            <div class="mp-kpis">
                <div class="mp-kpi">
                    <div class="mp-kpi-icon"><i class="bi bi-briefcase-fill"></i></div>
                    <div>
                        <div class="mp-kpi-value">@causas.Count</div>
                        <div class="mp-kpi-label">Causas</div>
                    </div>
                </div>
                <div class="mp-kpi-divider"></div>
                <div class="mp-kpi">
                    <div class="mp-kpi-icon"><i class="bi bi-journal-text"></i></div>
                    <div>
                        <div class="mp-kpi-value">@totalEventos</div>
                        <div class="mp-kpi-label">Eventos</div>
                    </div>
                </div>
                <div class="mp-kpi-divider"></div>
                <div class="mp-kpi @(plazosProximos > 0 ? "mp-kpi-warn" : "")">
                    <div class="mp-kpi-icon"><i class="bi bi-calendar-event-fill"></i></div>
                    <div>
                        <div class="mp-kpi-value">@plazosProximos</div>
                        <div class="mp-kpi-label">Plazos próximos</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ CONTENIDO ══════════════════════════════════════════════ -->
    <div class="container mp-body">
        <div class="row g-4 g-lg-5">

            <!-- ── Historial de causas (columna principal) ────────── -->
            <div class="col-lg-8">
                <div class="mp-section-head">
                    <span class="mp-section-eyebrow">Expediente</span>
                    <h2 class="mp-section-title">Historial de causas</h2>
                    <div class="mp-section-bar"></div>
                </div>

                @if (!causas.Any())
                {
                    <div class="mp-empty-state">
                        <i class="bi bi-folder-x mp-empty-icon"></i>
                        <span>No hay causas registradas en tu expediente aún.</span>
                    </div>
                }
                else
                {
                    <div class="mp-accordion">
                        @foreach (var causa in causas)
                        {
                            var ev = eventosPorCausa.GetValueOrDefault(causa.Id, new());
                            var isOpen = causaExpandida == causa.Id || causas.Count == 1;

                            <div class="mp-causa @(isOpen ? "mp-causa-open" : "")">

                                <!-- Cabecera clickeable -->
                                <button class="mp-causa-header" @onclick="() => ToggleCausa(causa.Id)">
                                    <div class="mp-causa-header-left">
                                        <div class="mp-causa-avatar">
                                            <i class="bi bi-briefcase"></i>
                                        </div>
                                        <div class="mp-causa-info">
                                            <span class="mp-causa-id">@causa.IdentificadorVisual</span>
                                            <div class="mp-causa-meta">
                                                <span>@(causa.Materia ?? "—")</span>
                                                @if (causa.FechaIngreso.HasValue)
                                                {
                                                    <span class="mp-causa-meta-sep">·</span>
                                                    <span>Ingreso: @causa.FechaIngreso.Value.ToString("dd/MM/yyyy")</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mp-causa-header-right">
                                        <span class="mp-estado-badge @GetEstadoBadge(causa.Estado)">
                                            @(causa.Estado ?? "Sin estado")
                                        </span>
                                        <div class="mp-chevron @(isOpen ? "mp-chevron-up" : "")">
                                            <i class="bi bi-chevron-down"></i>
                                        </div>
                                    </div>
                                </button>

                                <!-- Cuerpo (timeline de eventos) -->
                                <div class="mp-causa-body @(isOpen ? "mp-causa-body-open" : "")">
                                    <div class="mp-timeline-wrap">
                                        @if (!ev.Any())
                                        {
                                            <p class="mp-tl-empty">
                                                <i class="bi bi-hourglass-split me-2"></i>Aún no hay eventos procesales registrados.
                                            </p>
                                        }
                                        else
                                        {
                                            <div class="mp-timeline">
                                                @foreach (var e in ev)
                                                {
                                                    <div class="mp-tl-item">
                                                        <div class="mp-tl-track">
                                                            <div class="mp-tl-dot @(e.RequiereAsistencia ? "mp-tl-dot-gold" : "")">
                                                                @if (e.RequiereAsistencia)
                                                                {
                                                                    <i class="bi bi-calendar-check"></i>
                                                                }
                                                                else
                                                                {
                                                                    <i class="bi bi-file-text"></i>
                                                                }
                                                            </div>
                                                            <div class="mp-tl-line"></div>
                                                        </div>
                                                        <div class="mp-tl-content">
                                                            <div class="mp-tl-row">
                                                                <span class="mp-tl-tipo">@e.Tipo</span>
                                                                @if (e.FechaEvento.HasValue)
                                                                {
                                                                    <span class="mp-tl-fecha">
                                                                        @e.FechaEvento.Value.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("es-EC"))
                                                                    </span>
                                                                }
                                                            </div>
                                                            <p class="mp-tl-desc">@e.Descripcion</p>
                                                            @if (e.RequiereAsistencia && e.FechaHoraAgendada.HasValue)
                                                            {
                                                                <div class="mp-tl-audiencia">
                                                                    <i class="bi bi-clock-history"></i>
                                                                    <span>Audiencia: <strong>@e.FechaHoraAgendada.Value.ToString("dd/MM/yyyy 'a las' HH:mm")</strong></span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>

                            </div>
                        }
                    </div>
                }
            </div>

            <!-- ── Panel lateral ──────────────────────────────────── -->
            <div class="col-lg-4">

                <!-- Plazos próximos -->
                <div class="mp-side-card mb-4">
                    <div class="mp-side-header">
                        <div class="mp-side-header-icon"><i class="bi bi-bell-fill"></i></div>
                        <h3 class="mp-side-title">Próximos vencimientos</h3>
                    </div>
                    <div class="mp-side-body p-0">
                        @if (!plazos.Any())
                        {
                            <div class="mp-side-empty">
                                <i class="bi bi-check2-circle"></i>
                                <span>Sin plazos pendientes próximos.</span>
                            </div>
                        }
                        else
                        {
                            <ul class="mp-plazos-list">
                                @foreach (var p in plazos.Take(8))
                                {
                                    var dias = (p.FechaVencimiento.Date - DateTime.Today).Days;
                                    <li class="mp-plazo-item">
                                        <div class="mp-plazo-left">
                                            <span class="mp-plazo-title">@p.Titulo</span>
                                            <span class="mp-plazo-num">@p.NumeroProceso</span>
                                            <span class="mp-plazo-date"><i class="bi bi-calendar3 me-1"></i>@p.FechaVencimiento.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="mp-plazo-badge-wrap">
                                            @if (dias < 0)
                                            {
                                                <span class="mp-badge mp-badge-danger">Vencido</span>
                                            }
                                            else if (dias == 0)
                                            {
                                                <span class="mp-badge mp-badge-danger">Hoy</span>
                                            }
                                            else if (dias <= 3)
                                            {
                                                <span class="mp-badge mp-badge-warn">@dias d</span>
                                            }
                                            else
                                            {
                                                <span class="mp-badge mp-badge-ok">@dias d</span>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>

                <!-- Contacto rápido -->
                <div class="mp-support-card">
                    <div class="mp-support-orb"></div>
                    <div class="mp-support-inner">
                        <div class="mp-support-icon"><i class="bi bi-headset"></i></div>
                        <h4 class="mp-support-title">¿Tienes dudas?</h4>
                        <p class="mp-support-text">Nuestro equipo está disponible para acompañarte en cada etapa de tu proceso.</p>
                        <a href="/contacto" class="mp-support-btn">
                            <i class="bi bi-chat-text-fill me-2"></i>Contactar al estudio
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
}

<style>
    /* ═══════════════════════════════════════════════════════
       MI PORTAL — Lamilla Escudero Premium UI
       ═══════════════════════════════════════════════════════ */

    /* Variables locales del portal */
    .mp-loading-screen,
    .mp-not-linked,
    .mp-hero,
    .mp-body,
    .mp-accordion,
    .mp-side-card,
    .mp-support-card {
        --mp-navy: #0B1F3A;
        --mp-navy-mid: #142947;
        --mp-gold: #B8963E;
        --mp-gold-lt: #D4AF6A;
        --mp-gold-pale: #F5EDD7;
        --mp-ivory: #F8F6F1;
        --mp-cream: #F0EDE6;
        --mp-charcoal: #1C1C1E;
        --mp-silver: #8A8A8E;
        --mp-line: rgba(11,31,58,.08);
        --mp-white: #ffffff;
        --mp-radius-sm: 6px;
        --mp-radius-md: 10px;
        --mp-radius-lg: 16px;
        --mp-ease: cubic-bezier(.4,0,.2,1);
        --mp-t: 200ms;
        --mp-shadow-sm: 0 1px 4px rgba(11,31,58,.06);
        --mp-shadow-md: 0 4px 16px rgba(11,31,58,.10);
        --mp-shadow-lg: 0 10px 32px rgba(11,31,58,.14);
    }

    /* ── Loading ───────────────────────────────────────── */
    .mp-loading-screen {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.25rem;
        background: var(--mp-ivory);
    }

    .mp-spinner-ring {
        width: 44px;
        height: 44px;
        border: 3px solid rgba(184,150,62,.2);
        border-top-color: var(--mp-gold);
        border-radius: 50%;
        animation: mp-spin .7s linear infinite;
    }

    @@keyframes mp-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .mp-loading-text {
        font-size: .875rem;
        color: var(--mp-silver);
        letter-spacing: .02em;
    }

    /* ── Not linked ────────────────────────────────────── */
    .mp-not-linked {
        min-height: 70vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 1.5rem;
        background: var(--mp-ivory);
    }

    .mp-not-linked-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(184,150,62,.1);
        border: 2px solid rgba(184,150,62,.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--mp-gold);
        margin-bottom: 1.5rem;
    }

    .mp-not-linked-title {
        font-family: var(--font-display, Georgia, serif);
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--mp-navy);
        margin-bottom: .75rem;
    }

    .mp-not-linked-body {
        font-size: .95rem;
        color: var(--mp-silver);
        line-height: 1.7;
        max-width: 400px;
        margin-bottom: 2rem;
    }

    .mp-btn-primary {
        display: inline-flex;
        align-items: center;
        background: var(--mp-navy);
        color: var(--mp-white);
        padding: .7rem 1.5rem;
        border-radius: var(--mp-radius-md);
        font-size: .875rem;
        font-weight: 500;
        text-decoration: none;
        transition: background var(--mp-t) var(--mp-ease), transform 80ms;
    }

        .mp-btn-primary:hover {
            background: var(--mp-navy-mid);
            color: var(--mp-white);
        }

        .mp-btn-primary:active {
            transform: scale(.98);
        }

    /* ── HERO ──────────────────────────────────────────── */
    .mp-hero {
        position: relative;
        background: var(--mp-navy);
        padding: 3.5rem 0 5rem;
        overflow: hidden;
        isolation: isolate;
    }

    /* Trama de puntos sutil */
    .mp-hero-noise {
        position: absolute;
        inset: 0;
        opacity: .035;
        background-image: radial-gradient(circle, rgba(255,255,255,.8) 1px, transparent 1px);
        background-size: 24px 24px;
        pointer-events: none;
    }

    /* Anillos decorativos */
    .mp-hero-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(184,150,62,.12);
        pointer-events: none;
    }

    .mp-hero-ring-1 {
        width: 520px;
        height: 520px;
        top: -200px;
        right: -160px;
    }

    .mp-hero-ring-2 {
        width: 320px;
        height: 320px;
        bottom: -140px;
        left: -80px;
        border-color: rgba(184,150,62,.07);
    }

    .mp-hero-inner {
        position: relative;
        z-index: 1;
    }

    .mp-hero-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
    }

    .mp-eyebrow {
        display: block;
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: var(--mp-gold-lt);
        margin-bottom: .5rem;
    }

    .mp-welcome {
        font-family: var(--font-display, Georgia, serif);
        font-size: 2.4rem;
        font-weight: 600;
        color: var(--mp-white);
        line-height: 1.1;
        margin-bottom: .4rem;
    }

        .mp-welcome em {
            font-style: normal;
            color: var(--mp-gold-lt);
        }

    .mp-subwelcome {
        font-size: .95rem;
        color: rgba(255,255,255,.55);
        line-height: 1.65;
        max-width: 480px;
        margin: 0;
    }

    /* Logout button */
    .mp-logout-form {
        margin: 0;
    }

    .mp-logout-btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: rgba(255,255,255,.07);
        color: rgba(255,255,255,.7);
        border: 1px solid rgba(255,255,255,.12);
        border-radius: var(--mp-radius-md);
        padding: .55rem 1rem;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        transition: all var(--mp-t) var(--mp-ease);
    }

        .mp-logout-btn:hover {
            background: rgba(255,255,255,.13);
            color: var(--mp-white);
            border-color: rgba(255,255,255,.22);
        }

    /* KPIs en hero */
    .mp-kpis {
        display: inline-flex;
        align-items: center;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.09);
        border-radius: var(--mp-radius-lg);
        overflow: hidden;
        backdrop-filter: blur(8px);
    }

    .mp-kpi {
        display: flex;
        align-items: center;
        gap: .875rem;
        padding: 1.1rem 1.75rem;
        transition: background var(--mp-t);
    }

        .mp-kpi:hover {
            background: rgba(255,255,255,.05);
        }

        .mp-kpi.mp-kpi-warn .mp-kpi-value {
            color: #F5D47A;
        }

        .mp-kpi.mp-kpi-warn .mp-kpi-icon {
            color: #F5D47A;
        }

    .mp-kpi-divider {
        width: 1px;
        height: 36px;
        background: rgba(255,255,255,.09);
        flex-shrink: 0;
    }

    .mp-kpi-icon {
        font-size: 1.2rem;
        color: rgba(255,255,255,.35);
        line-height: 1;
    }

    .mp-kpi-value {
        font-family: var(--font-display, Georgia, serif);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--mp-white);
        line-height: 1;
        display: block;
    }

    .mp-kpi-label {
        font-size: .68rem;
        color: rgba(255,255,255,.4);
        text-transform: uppercase;
        letter-spacing: .06em;
        display: block;
        margin-top: 2px;
    }

    /* ── CONTENIDO ─────────────────────────────────────── */
    .mp-body {
        padding-top: 3rem;
        padding-bottom: 4rem;
        background: var(--mp-ivory);
        /* Solapa sobre el hero */
        margin-top: -2rem;
        border-radius: 20px 20px 0 0;
        position: relative;
        z-index: 2;
        box-shadow: 0 -4px 20px rgba(11,31,58,.08);
    }

    /* Encabezado de sección */
    .mp-section-head {
        margin-bottom: 2rem;
    }

    .mp-section-eyebrow {
        display: block;
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .13em;
        text-transform: uppercase;
        color: var(--mp-gold);
        margin-bottom: .3rem;
    }

    .mp-section-title {
        font-family: var(--font-display, Georgia, serif);
        font-size: 1.45rem;
        font-weight: 600;
        color: var(--mp-navy);
        margin-bottom: .6rem;
    }

    .mp-section-bar {
        width: 40px;
        height: 3px;
        background: var(--mp-gold);
        border-radius: 2px;
    }

    /* Empty state */
    .mp-empty-state {
        background: var(--mp-white);
        border: 1.5px dashed rgba(184,150,62,.3);
        border-radius: var(--mp-radius-lg);
        padding: 4rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        color: var(--mp-silver);
        font-size: .875rem;
        text-align: center;
    }

    .mp-empty-icon {
        font-size: 2.25rem;
        color: rgba(184,150,62,.4);
        display: block;
    }

    /* ── ACORDEÓN DE CAUSAS ────────────────────────────── */
    .mp-accordion {
        display: flex;
        flex-direction: column;
        gap: .875rem;
    }

    .mp-causa {
        background: var(--mp-white);
        border: 1px solid rgba(11,31,58,.09);
        border-radius: var(--mp-radius-lg);
        box-shadow: var(--mp-shadow-sm);
        overflow: hidden;
        transition: box-shadow var(--mp-t) var(--mp-ease), border-color var(--mp-t) var(--mp-ease);
    }

        .mp-causa:hover {
            box-shadow: var(--mp-shadow-md);
            border-color: rgba(184,150,62,.3);
        }

        .mp-causa.mp-causa-open {
            border-color: rgba(184,150,62,.4);
            box-shadow: var(--mp-shadow-md), inset 3px 0 0 var(--mp-gold);
        }

    /* Cabecera */
    .mp-causa-header {
        width: 100%;
        background: none;
        border: none;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        cursor: pointer;
        text-align: left;
        transition: background var(--mp-t);
    }

        .mp-causa-header:hover {
            background: var(--mp-ivory);
        }

        .mp-causa-header:focus-visible {
            outline: 2px solid var(--mp-gold);
            outline-offset: -2px;
        }

    .mp-causa-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 0;
    }

    .mp-causa-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: rgba(11,31,58,.06);
        border: 1px solid rgba(11,31,58,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: var(--mp-navy);
        flex-shrink: 0;
        transition: all var(--mp-t);
    }

    .mp-causa-open .mp-causa-avatar {
        background: rgba(184,150,62,.1);
        border-color: rgba(184,150,62,.35);
        color: var(--mp-gold);
    }

    .mp-causa-info {
        min-width: 0;
    }

    .mp-causa-id {
        display: block;
        font-size: .95rem;
        font-weight: 600;
        color: var(--mp-navy);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: .2rem;
    }

    .mp-causa-meta {
        font-size: .78rem;
        color: var(--mp-silver);
        display: flex;
        align-items: center;
        gap: .35rem;
        flex-wrap: wrap;
    }

    .mp-causa-meta-sep {
        opacity: .4;
    }

    .mp-causa-header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
