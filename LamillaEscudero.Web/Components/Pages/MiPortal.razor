@code {
    private LamillaEscudero.Application.Models.Clientes.ClienteResponse? cliente;
    private List<LamillaEscudero.Application.Models.Causas.CausaResponse> causas = new();
    private Dictionary<Guid, List<LamillaEscudero.Application.Models.Eventos.EventoProcesalResponse>> eventosPorCausa = new();
    private List<LamillaEscudero.Application.Models.Plazos.PlazoResponse> plazos = new();
    private bool cargando = true;
    private Guid? causaExpandida;
    private int totalEventos;
    private int plazosProximos;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var user = auth.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            cargando = false;
            return;
        }

        // Buscar el cliente vinculado a este userId
        var todosClientes = await ClienteService.GetAllAsync();
        // Nota: en producción agrega GetByUserIdAsync al servicio para eficiencia
        cliente = todosClientes.FirstOrDefault(c =>
            c.UserId == userId ||
            c.Email?.Equals(user.FindFirst(ClaimTypes.Email)?.Value,
                StringComparison.OrdinalIgnoreCase) == true);

        if (cliente is not null)
        {
            causas = await CausaService.GetByClienteIdAsync(cliente.Id);

            foreach (var causa in causas)
            {
                var ev = await EventoService.GetByCausaIdAsync(causa.Id);
                eventosPorCausa[causa.Id] = ev.OrderByDescending(x => x.FechaEvento ?? x.CreatedAt).ToList();
            }

            totalEventos = eventosPorCausa.Values.Sum(x => x.Count);

            // Plazos próximos de todas las causas del cliente
            var todosPlazos = await PlazoService.GetAllAsync();
            var causaIds = causas.Select(c => c.Id).ToHashSet();
            plazos = todosPlazos
                .Where(p => causaIds.Contains(p.CausaId) && !p.Cumplido)
                .OrderBy(p => p.FechaVencimiento)
                .ToList();
            plazosProximos = plazos.Count(p => (p.FechaVencimiento.Date - DateTime.Today).Days <= 7);

            // Expandir primera causa por defecto
            if (causas.Count == 1) causaExpandida = causas[0].Id;
        }

        cargando = false;
    }

    private void ToggleCausa(Guid id)
        => causaExpandida = causaExpandida == id ? null : id;

    private static string GetEstadoBadge(string? estado) => estado switch
    {
        "Activa" => "dash-badge-ok",
        "En juicio" => "dash-badge-warning",
        "Instrucción fiscal" => "dash-badge-warning",
        "Archivada" => "",
        "Concluida" => "",
        _ => "dash-badge-ok"
    };
}
