@* ════════════════════════════════════════════════════════════
   ChatbotPublico.razor — Chatbot con máquina de estados
   Captura leads (nombre, email, teléfono, asunto, mensaje)
   y los guarda automáticamente via IConsultaWebService.
   ════════════════════════════════════════════════════════════ *@
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.Extensions.Configuration
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject IConsultaWebService ConsultaService
@inject IPublicChatService PublicChatService

<button class="chat-fab @(!isOpen ? "chat-fab-pulse" : "")"
        type="button"
        title="¿En qué podemos ayudarte?"
        @onclick="ToggleChat">
    <i class="bi @(isOpen ? "bi-x-lg" : "bi-chat-dots-fill")"></i>
    @if (badgeCount > 0 && !isOpen)
    {
        <span class="chat-fab-badge">@badgeCount</span>
    }
</button>

@if (isOpen)
{
    <div class="chat-window">

        <div class="chat-header">
            <div class="chat-header-avatar">
                <i class="bi bi-robot"></i>
            </div>
            <div class="chat-header-info">
                <span class="chat-header-name">Asistente Legal LE</span>
                <span class="chat-header-status">
                    <span class="chat-online-dot"></span>En línea
                </span>
                <span class="chat-header-tag">Orientación inicial y captura segura de consultas</span>
            </div>
            <button class="chat-close-btn" type="button" @onclick="ToggleChat" title="Cerrar">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="chat-messages" @ref="messagesContainer">
            @foreach (var msg in messages)
            {
                <div class="chat-msg @(msg.IsBot ? "chat-msg-bot" : "chat-msg-user")">
                    <div class="chat-bubble">
                        @if (msg.IsHtml)
                        {
                            @((Microsoft.AspNetCore.Components.MarkupString)msg.Text)
                        }
                        else
                        {
                            @msg.Text
                        }
                    </div>
                    <span class="chat-msg-time">@msg.Time.ToString("HH:mm")</span>
                </div>
            }
            @if (isTyping)
            {
                <div class="chat-msg chat-msg-bot">
                    <div class="chat-bubble chat-typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            }
        </div>

        @if (suggestions.Any() && !isTyping)
        {
            <div class="chat-suggestions">
                @foreach (var s in suggestions)
                {
                    <button class="chat-suggestion-btn" type="button" @onclick="() => SendSuggestion(s)">@s</button>
                }
            </div>
        }

        <div class="chat-disclaimer">
            La orientación inicial no sustituye el análisis completo de un abogado del estudio.
        </div>

        <div class="chat-input-row">
            <input class="chat-input"
                   type="@inputType"
                   placeholder="@inputPlaceholder"
                   @ref="chatInput"
                   @bind="inputText"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   maxlength="500" />
            <button class="chat-mic-btn @(isListening ? "chat-mic-btn-listening" : "")"
                    type="button"
                    @onclick="ToggleVoiceInputAsync"
                    title="Dictar mensaje">
                <i class="bi @(isListening ? "bi-mic-fill" : "bi-mic")"></i>
            </button>
            <button class="chat-send-btn" type="button" @onclick="SendUserMessage" title="Enviar">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
    </div>
}

@code {
    // ── Estado base ───────────────────────────────────────────────
    private bool isOpen;
    private bool isTyping;
    private int badgeCount;
    private string inputText = string.Empty;
    private string inputType = "text";
    private string inputPlaceholder = "Escribe tu mensaje...";
    private bool isListening;
    private bool jsReady;
    private bool isDisposed;
    private bool scrollAfterRender;
    private string? pendingSpeechText;
    private long pendingSpeechVersion;
    private string elevenLabsApiKey = string.Empty;
    private string elevenLabsVoiceId = string.Empty;
    private ElementReference chatInput;
    private ElementReference messagesContainer;
    private DotNetObjectReference<ChatbotPublico>? voiceInteropRef;
    private List<string> suggestions = new();

    private record ChatMessage(string Text, bool IsBot, DateTime Time, bool IsHtml = false);
    private List<ChatMessage> messages = new();

    // ── Máquina de estados para captura de lead ───────────────────
    private enum LeadStep { None, Nombre, Email, Telefono, Asunto, Mensaje, Confirmar, Guardado }
    private LeadStep leadStep = LeadStep.None;

    private string leadNombre = string.Empty;
    private string leadEmail = string.Empty;
    private string leadTelefono = string.Empty;
    private string leadAsunto = string.Empty;
    private string leadMensaje = string.Empty;

    // ── Init ──────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        elevenLabsApiKey = Configuration["ElevenLabs:ApiKey"]?.Trim() ?? string.Empty;
        elevenLabsVoiceId = Configuration["ElevenLabs:VoiceId"]?.Trim() ?? string.Empty;

        messages.Add(new(
            "👋 ¡Hola! Soy el asistente virtual de <strong>Lamilla Escudero &amp; Asociados</strong>. " +
            "Puedo orientarte sobre nuestros servicios o ayudarte a enviar una consulta.",
            true, DateTime.Now, IsHtml: true));
        SetSuggestions("inicio");
        badgeCount = 1;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            jsReady = true;
        }

        if (!jsReady || isDisposed)
        {
            return;
        }

        if (scrollAfterRender)
        {
            scrollAfterRender = false;
            await ScrollToBottom();
        }

        if (string.IsNullOrWhiteSpace(pendingSpeechText))
        {
            return;
        }

        var speechText = pendingSpeechText;
        var speechVersion = pendingSpeechVersion;
        pendingSpeechText = null;

        await GenerateAndPlaySpeechAsync(speechText, speechVersion);
    }

    private Task ToggleChat()
    {
        isOpen = !isOpen;
        badgeCount = 0;
        return Task.CompletedTask;
    }

    // ── Envío de mensajes ─────────────────────────────────────────
    private async Task SendUserMessage()
    {
        var text = inputText.Trim();
        if (string.IsNullOrWhiteSpace(text))
        {
            return;
        }

        inputText = string.Empty;

        messages.Add(new(text, false, DateTime.Now));
        suggestions = new();
        isTyping = true;
        scrollAfterRender = true;
        StateHasChanged();

        await Task.Delay(600);
        isTyping = false;

        await ProcessInput(text);
        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task SendSuggestion(string text)
    {
        inputText = text;
        await SendUserMessage();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendUserMessage();
    }

    // ── Motor principal ───────────────────────────────────────────
    private async Task ProcessInput(string text)
    {
        if (leadStep != LeadStep.None && leadStep != LeadStep.Guardado)
        {
            await ProcessLeadInput(text);
            return;
        }

        var reply = await PublicChatService.GetReplyAsync(text);

        if (reply.StartLeadCapture)
        {
            StartLeadCapture();
            await Bot(reply.Message, isHtml: reply.IsHtml, speechText: reply.SpeechText);
            return;
        }

        await Bot(reply.Message, isHtml: reply.IsHtml, speechText: reply.SpeechText);
        SetSuggestions(reply.SuggestionContext);
    }

    // ── Máquina de estados Lead ───────────────────────────────────
    private async Task ProcessLeadInput(string text)
    {
        switch (leadStep)
        {
            case LeadStep.Nombre:
                leadNombre = text;
                leadStep = LeadStep.Email;
                inputType = "email";
                inputPlaceholder = "Tu correo electrónico...";
                await Bot($"Encantado, {leadNombre} 👋. ¿Cuál es tu correo electrónico? <em>(o escribe «omitir»)</em>",
                    isHtml: true,
                    speechText: $"Encantado, {leadNombre}. ¿Cuál es tu correo electrónico? Puedes decir omitir.");
                break;

            case LeadStep.Email:
                leadEmail = text.ToLowerInvariant() == "omitir" ? "" : text;
                leadStep = LeadStep.Telefono;
                inputType = "tel";
                inputPlaceholder = "Tu número de teléfono...";
                await Bot("¿Y tu número de teléfono? <em>(o escribe «omitir»)</em>",
                    isHtml: true,
                    speechText: "¿Y tu número de teléfono? Puedes decir omitir.");
                break;

            case LeadStep.Telefono:
                leadTelefono = text.ToLowerInvariant() == "omitir" ? "" : text;
                leadStep = LeadStep.Asunto;
                inputType = "text";
                inputPlaceholder = "Ej. Consulta laboral, divorcio...";
                await Bot("¿Cuál es el asunto o motivo de tu consulta?");
                break;

            case LeadStep.Asunto:
                leadAsunto = text;
                leadStep = LeadStep.Mensaje;
                inputPlaceholder = "Describe brevemente tu situación...";
                await Bot("Cuéntame un poco más sobre tu situación para que el abogado pueda prepararse mejor:");
                break;

            case LeadStep.Mensaje:
                leadMensaje = text;
                leadStep = LeadStep.Confirmar;
                inputPlaceholder = "Escribe tu mensaje...";
                await MostrarResumen();
                suggestions = new List<string> { "✅ Sí, enviar", "✏️ Corregir algo" };
                break;

            case LeadStep.Confirmar:
                if (Matches(text.ToLowerInvariant(), "sí", "si", "enviar", "confirmar", "correcto", "ok"))
                {
                    await GuardarLead();
                }
                else
                {
                    StartLeadCapture();
                    await Bot("Sin problema, empecemos de nuevo. ¿Cuál es tu nombre completo?");
                    suggestions = new();
                }
                break;
        }
    }

    private Task MostrarResumen()
    {
        var htmlEmail = string.IsNullOrWhiteSpace(leadEmail) ? "" : $"📧 <strong>Email:</strong> {EscHtml(leadEmail)}<br>";
        var htmlTel = string.IsNullOrWhiteSpace(leadTelefono) ? "" : $"📱 <strong>Teléfono:</strong> {EscHtml(leadTelefono)}<br>";

        var resumen =
            "<strong>📋 Resumen de tu consulta:</strong><br>" +
            $"👤 <strong>Nombre:</strong> {EscHtml(leadNombre)}<br>" +
            htmlEmail +
            htmlTel +
            $"📌 <strong>Asunto:</strong> {EscHtml(leadAsunto)}<br>" +
            $"💬 <strong>Mensaje:</strong> {EscHtml(leadMensaje)}<br><br>" +
            "¿Es correcto? Te avisaré por aquí cuando hayamos registrado tu consulta.";

        return BotHtml(
            resumen,
            speechText: "Te mostré el resumen de tu consulta. Si todo está correcto, puedes decir sí, enviar.");
    }

    private async Task GuardarLead()
    {
        leadStep = LeadStep.Guardado;
        await Bot("⏳ Registrando tu consulta...", speak: false);
        isTyping = true;
        StateHasChanged();

        await Task.Delay(800);
        isTyping = false;

        try
        {
            var request = new LamillaEscudero.Application.Models.Consultas.ConsultaWebCreateRequest
            {
                Nombre = leadNombre,
                Email = string.IsNullOrWhiteSpace(leadEmail) ? null : leadEmail,
                Telefono = string.IsNullOrWhiteSpace(leadTelefono) ? null : leadTelefono,
                Asunto = leadAsunto,
                Mensaje = leadMensaje
            };

            var result = await ConsultaService.CreateAsync(request);

            if (result is not null)
            {
                await BotHtml(
                    "✅ <strong>¡Consulta registrada exitosamente!</strong><br>" +
                    $"Hemos guardado tu solicitud, {EscHtml(leadNombre)}. Un miembro del equipo " +
                    "la revisará y se pondrá en contacto contigo a la brevedad.<br><br>" +
                    "También puedes llamarnos o visitar nuestra oficina si lo prefieres. ¡Gracias por confiar en nosotros! 🙏",
                    speechText: $"Consulta registrada exitosamente. Gracias, {leadNombre}. Un miembro del equipo se pondrá en contacto contigo a la brevedad."
                );
                SetSuggestions("fin");
                badgeCount = 0;
                ResetLeadCaptureState();
            }
            else
            {
                await BotHtml(
                    "❌ Hubo un problema al registrar tu consulta. Por favor intenta más tarde " +
                    "o escríbenos directamente a través de la página de <a href='/contacto' style='color:var(--gold)'>Contacto</a>.",
                    speechText: "Hubo un problema al registrar tu consulta. Por favor intenta más tarde o usa la página de contacto."
                );
                ResetLeadCaptureState();
                SetSuggestions("inicio");
            }
        }
        catch
        {
            await Bot("❌ Ocurrió un error. Por favor intenta desde la página de Contacto.");
            ResetLeadCaptureState();
            SetSuggestions("inicio");
        }

        ResetLeadData();
    }

    // ── Helpers ───────────────────────────────────────────────────

    private Task Bot(
        string text,
        bool isHtml = false,
        string? speechText = null,
        bool speak = true)
        => AddBotMessageAsync(text, isHtml, speechText, speak);

    private Task BotHtml(string html, string? speechText = null, bool speak = true)
        => AddBotMessageAsync(html, true, speechText, speak);

    private async Task AddBotMessageAsync(
        string message,
        bool isHtml,
        string? speechText = null,
        bool speak = true)
    {
        messages.Add(new(message, true, DateTime.Now, isHtml));
        scrollAfterRender = true;

        if (!speak || !jsReady || isDisposed)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var textForSpeech = string.IsNullOrWhiteSpace(speechText)
            ? ToSpeechText(message, isHtml)
            : speechText;

        if (string.IsNullOrWhiteSpace(textForSpeech))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        pendingSpeechText = textForSpeech;
        pendingSpeechVersion++;
        await InvokeAsync(StateHasChanged);
    }

    private static bool Matches(string input, params string[] keywords)
        => keywords.Any(k => input.Contains(k, StringComparison.OrdinalIgnoreCase));

    private static string EscHtml(string? s)
        => System.Net.WebUtility.HtmlEncode(s ?? string.Empty);

    private static string ToSpeechText(string value, bool isHtml)
    {
        if (!isHtml)
        {
            return value;
        }

        var withoutTags = System.Text.RegularExpressions.Regex.Replace(value, "<[^>]+>", " ");
        var decoded = System.Net.WebUtility.HtmlDecode(withoutTags);
        return System.Text.RegularExpressions.Regex.Replace(decoded, @"\s+", " ").Trim();
    }

    private void StartLeadCapture()
    {
        leadStep = LeadStep.Nombre;
        inputType = "text";
        inputPlaceholder = "Tu nombre completo...";
        suggestions = new();
    }

    private void ResetLeadCaptureState()
    {
        leadStep = LeadStep.None;
        inputType = "text";
        inputPlaceholder = "Escribe tu mensaje...";
    }

    private void ResetLeadData()
        => leadNombre = leadEmail = leadTelefono = leadAsunto = leadMensaje = string.Empty;

    private void SetSuggestions(string context)
    {
        suggestions = context switch
        {
            "inicio" => new() { "¿Qué servicios ofrecen?", "Quiero agendar una cita", "Horarios de atención" },
            "servicios" => new() { "Quiero agendar una consulta", "¿Cuánto cobran?", "¿Dónde están?" },
            "contacto" => new() { "Quiero agendar una consulta", "¿Qué servicios ofrecen?", "¿Dónde están?" },
            "horario" => new() { "Quiero agendar una cita", "¿Cuánto cobran?" },
            "precios" => new() { "Agendar consulta gratuita", "¿Dónde están?" },
            "ubicacion" => new() { "Agendar una cita", "Ver página de contacto" },
            "fin" => new() { "Tengo otra pregunta", "Ver servicios" },
            _ => new()
        };
    }

    private async Task ScrollToBottom()
    {
        if (!jsReady || isDisposed)
        {
            return;
        }

        await JS.InvokeVoidAsync("voiceChat.scrollToBottom", messagesContainer);
    }

    private async Task ToggleVoiceInputAsync()
    {
        if (isListening)
        {
            await JS.InvokeVoidAsync("voiceChat.stopRecognition");
            return;
        }

        voiceInteropRef ??= DotNetObjectReference.Create(this);
        var supported = await JS.InvokeAsync<bool>(
            "voiceChat.startRecognition",
            chatInput,
            voiceInteropRef,
            "es-EC");

        if (!supported)
        {
            await Bot("Tu navegador no soporta reconocimiento de voz nativo. Puedes seguir escribiendo tu consulta.", speak: false);
            await ScrollToBottom();
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnSpeechRecognized(string transcript)
        => InvokeAsync(() =>
        {
            inputText = transcript ?? string.Empty;
            StateHasChanged();
        });

    [JSInvokable]
    public Task OnVoiceStateChanged(bool listening)
        => InvokeAsync(() =>
        {
            isListening = listening;
            StateHasChanged();
        });

    [JSInvokable]
    public Task OnVoiceError(string message)
        => InvokeAsync(async () =>
        {
            isListening = false;
            if (!string.IsNullOrWhiteSpace(message))
            {
                await Bot(message, speak: false);
                await ScrollToBottom();
            }

            StateHasChanged();
        });

    private async Task GenerateAndPlaySpeechAsync(string text, long speechVersion)
    {
        if (string.IsNullOrWhiteSpace(text)
            || string.IsNullOrWhiteSpace(elevenLabsApiKey)
            || string.IsNullOrWhiteSpace(elevenLabsVoiceId)
            || isDisposed
            || speechVersion != pendingSpeechVersion)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync(
                "generateAndPlayElevenLabs",
                text,
                elevenLabsApiKey,
                elevenLabsVoiceId);
        }
        catch
        {
            // El audio es opcional: nunca debe romper la respuesta del chat.
        }
    }

    public async ValueTask DisposeAsync()
    {
        isDisposed = true;

        if (jsReady)
        {
            try
            {
                await JS.InvokeVoidAsync("voiceChat.stopRecognition");
            }
            catch
            {
                // Ignoramos errores al cerrar el circuito.
            }
        }

        voiceInteropRef?.Dispose();
    }
}

<style>
    /* FAB */
    .chat-fab {
        position: fixed;
        bottom: 1.75rem;
        right: 1.75rem;
        z-index: 1050;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        border: none;
        background: var(--navy,#0B1F3A);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        box-shadow: 0 4px 20px rgba(11,31,58,.35);
        transition: transform 150ms, box-shadow 150ms;
    }

        .chat-fab:hover {
            transform: scale(1.08);
            box-shadow: 0 6px 28px rgba(11,31,58,.45);
        }

    .chat-fab-pulse {
        animation: chat-pulse 2.5s infinite;
    }

    @@keyframes chat-pulse {
        0%,100%

    {
        box-shadow: 0 4px 20px rgba(11,31,58,.35),0 0 0 0 rgba(11,31,58,.25);
    }

    50% {
        box-shadow: 0 4px 20px rgba(11,31,58,.35),0 0 0 10px rgba(11,31,58,0);
    }

    }

    .chat-fab-badge {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #DC2626;
        color: #fff;
        font-size: .65rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    /* Ventana */
    .chat-window {
        position: fixed;
        bottom: 6rem;
        right: 1.75rem;
        z-index: 1049;
        width: 360px;
        max-width: calc(100vw - 2rem);
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 16px 56px rgba(11,31,58,.2);
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(11,31,58,.08);
        animation: chat-slide-in 200ms ease;
    }

    @@keyframes chat-slide-in {
        from

    {
        opacity: 0;
        transform: translateY(16px) scale(.97);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    }

    /* Header */
    .chat-header {
        background: var(--navy,#0B1F3A);
        padding: .875rem 1rem;
        border-radius: 16px 16px 0 0;
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .chat-header-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50;
        flex-shrink: 0;
        background: rgba(255,255,255,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: #fff;
        border-radius: 50%;
    }

    .chat-header-info {
        flex: 1;
    }

    .chat-header-name {
        display: block;
        font-size: .875rem;
        font-weight: 600;
        color: #fff;
    }

    .chat-header-status {
        display: flex;
        align-items: center;
        gap: .35rem;
        font-size: .72rem;
        color: rgba(255,255,255,.55);
    }

    .chat-online-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #22C55E;
    }

    .chat-close-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,.6);
        cursor: pointer;
        padding: .25rem;
        font-size: .875rem;
        line-height: 1;
    }

        .chat-close-btn:hover {
            color: #fff;
        }

    /* Mensajes */
    .chat-messages {
        height: 300px;
        overflow-y: auto;
        padding: .875rem;
        display: flex;
        flex-direction: column;
        gap: .625rem;
    }

        .chat-messages::-webkit-scrollbar {
            width: 4px;
        }

        .chat-messages::-webkit-scrollbar-thumb {
            background: var(--light-gray,#e8e6e1);
            border-radius: 2px;
        }

    .chat-msg {
        display: flex;
        flex-direction: column;
        max-width: 82%;
    }

    .chat-msg-bot {
        align-self: flex-start;
    }

    .chat-msg-user {
        align-self: flex-end;
    }

    .chat-bubble {
        padding: .6rem .875rem;
        border-radius: 12px;
        font-size: .85rem;
        line-height: 1.55;
    }

    .chat-msg-bot .chat-bubble {
        background: var(--ivory,#f8f6f1);
        color: var(--charcoal,#1c1c1e);
        border-radius: 4px 12px 12px 12px;
    }

    .chat-msg-user .chat-bubble {
        background: var(--navy,#0B1F3A);
        color: #fff;
        border-radius: 12px 4px 12px 12px;
    }

    .chat-msg-time {
        font-size: .68rem;
        color: var(--silver,#8a8a8e);
        margin-top: .2rem;
    }

    .chat-msg-bot .chat-msg-time {
        align-self: flex-start;
    }

    .chat-msg-user .chat-msg-time {
        align-self: flex-end;
    }

    /* Typing indicator */
    .chat-typing-indicator {
        display: flex;
        gap: .35rem;
        align-items: center;
        padding: .5rem .875rem;
    }

        .chat-typing-indicator span {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--silver,#8a8a8e);
            animation: typing-dot 1.2s infinite;
        }

            .chat-typing-indicator span:nth-child(2) {
                animation-delay: .2s;
            }

            .chat-typing-indicator span:nth-child(3) {
                animation-delay: .4s;
            }

    @@keyframes typing-dot {
        0%,60%,100%

    {
        transform: translateY(0);
        opacity: .4;
    }

    30% {
        transform: translateY(-5px);
        opacity: 1;
    }

    }

    /* Sugerencias */
    .chat-suggestions {
        padding: .5rem .875rem;
        display: flex;
