        flex-direction: column;
        align-items: center;
        text-align: center;
        overflow-y: auto;
    }

        .bio-left::-webkit-scrollbar {
            width: 4px;
        }

        .bio-left::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.1);
        }

    .bio-photo-wrap {
