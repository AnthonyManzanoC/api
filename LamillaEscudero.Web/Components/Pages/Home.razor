    .bio-name {
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--white);
        margin: 0 0 .35rem;
    }

    .bio-cargo {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--gold-light);
        margin: 0 0 1.25rem;
    }

    .bio-frase {
        font-family: var(--font-display);
        font-style: italic;
        font-size: .95rem;
        color: rgba(255,255,255,.7);
        margin: 0 0 1.5rem;
        padding: 0;
        line-height: 1.65;
    }

    .bio-quote-icon {
        color: var(--gold);
        opacity: .5;
        margin-right: .25rem;
    }

    .bio-contact-links {
        display: flex;
        flex-direction: column;
        gap: .5rem;
        width: 100%;
    }

    .bio-contact-link {
        display: flex;
        align-items: center;
        gap: .625rem;
        font-size: .8rem;
        color: rgba(255,255,255,.6);
        padding: .5rem .75rem;
        border-radius: var(--radius-sm);
        background: rgba(255,255,255,.05);
        transition: all var(--transition);
    }

        .bio-contact-link:hover {
            background: rgba(255,255,255,.1);
            color: var(--white);
        }

    .bio-linkedin {
        color: #7ab8d8 !important;
