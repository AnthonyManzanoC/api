@* ════════════════════════════════════════════════════════════════
   EQUIPO
   ════════════════════════════════════════════════════════════════ *@
@if (miembros is not null && miembros.Any())
{
    <section class="team-section team-v2">
        <div class="container">
            <div class="section-header reveal">
                <span class="section-eyebrow">Las personas detrás del estudio</span>
                <h2 class="section-title">Nuestro equipo</h2>
                <div class="section-title-line"></div>
                <p class="section-subtitle">Abogados comprometidos, especializados y con vocación de servicio.</p>
            </div>
            <div class="team-grid team-grid-v2">
                @foreach (var m in miembros)
                {
                    var isExpanded = expandedMiembroId == m.Id;
                    var tImgSrc = !string.IsNullOrWhiteSpace(m.PhotoData) ? m.PhotoData
                    : !string.IsNullOrWhiteSpace(m.FotoUrl) ? m.FotoUrl : null;
                    <div class="team-card team-card-v2 @(isExpanded ? "team-card-expanded" : "") reveal"
                         @onclick="() => ToggleMiembro(m.Id)">
                        <div class="team-avatar team-avatar-v2">
                            @if (tImgSrc is not null)
                            {
                                <img src="@tImgSrc" alt="@m.Nombres" class="team-photo" />
                            }
                            else
                            {

                                <div class="team-initials">@GetInitials(m.Nombres)</div>
                            }
                            <div class="team-avatar-ring"></div>
                        </div>
                        <h3 class="team-name">@m.Nombres</h3>
                        <p class="team-cargo">@m.Cargo</p>
                        @if (!string.IsNullOrWhiteSpace(m.BiografiaBreve))
                        {
                            <p class="team-bio-breve">@m.BiografiaBreve</p>
                        }
                        @if (isExpanded)
                        {
                            <div class="team-bio-full team-bio-full-v2">
                                <div class="team-bio-divider"></div>
                                @if (!string.IsNullOrWhiteSpace(m.FraseDestacada))
                                {
                                    <p class="team-bio-frase">
                                        <i class="bi bi-quote me-1" style="color:var(--gold);"></i>@m.FraseDestacada
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(m.BiografiaCompleta))
                                {
                                    <p class="team-bio-text">@m.BiografiaCompleta</p>
                                }
                                <div class="team-bio-actions">
                                    @if (!string.IsNullOrWhiteSpace(m.LinkedIn))
                                    {
                                        <a href="@m.LinkedIn" target="_blank" class="team-linkedin" @onclick:stopPropagation>
                                            <i class="bi bi-linkedin me-1"></i>LinkedIn
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(m.Email))
                                    {
                                        <a href="mailto:@m.Email" class="team-linkedin team-email-link" @onclick:stopPropagation>
                                            <i class="bi bi-envelope-fill me-1"></i>Email
                                        </a>
                                    }
                                    <button class="team-btn-overlay" @onclick="() => AbrirOverlay(m)" @onclick:stopPropagation>
                                        <i class="bi bi-person-badge me-1"></i>Ver perfil completo
                                    </button>
                                </div>
                            </div>
                        }
                        <span class="team-expand-hint">
                            <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </span>
                    </div>
                }
            </div>
        </div>
    </section>
}

@* ════════════════════════════════════════════════════════════════
   TESTIMONIOS DINÁMICOS (FASE 10)
   ════════════════════════════════════════════════════════════════ *@
<section class="testimonios-section py-5" style="background:var(--navy); position:relative;">
    <div class="container" style="position:relative; z-index:2;">

        <div class="section-header text-center mb-4">
            <span class="section-eyebrow" style="color:var(--gold-light);">Lo que dicen nuestros clientes</span>
            <h2 class="section-title" style="color:var(--white);">Testimonios</h2>
            <div class="section-title-line"></div>
        </div>

        @if (_testimonios.Count > 0)
        {
            @* ── Carrusel ── *@
            <div class="testi-carousel mb-5" @onmouseenter="PausarCarrusel" @onmouseleave="ReanudarCarrusel">
                <div class="testi-track" style="transform:translateX(-@(_carruselIndex * 100)%)">
                    @foreach (var t in _testimonios)
                    {
                        <div class="testi-slide">
                            <div class="testimonial-card">
                                <div class="tc-stars mb-3">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var fi = i;
                                        <i class="bi @(fi <= t.Calificacion ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                                <p class="tc-quote">"@t.Comentario"</p>
                                <div class="tc-author">
                                    <div class="tc-author-avatar">@t.Nombre[..1].ToUpper()</div>
                                    <div>
                                        <strong class="tc-author-name">@t.Nombre</strong>
                                        <span class="tc-author-case">@t.CreatedAt.ToString("MMMM yyyy")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                @if (_testimonios.Count > 1)
                {
                    <div class="testi-dots mt-4 text-center">
                        @for (int i = 0; i < _testimonios.Count; i++)
                        {
                            var idx = i;
                            <button class="testi-dot @(idx == _carruselIndex ? "active" : "")"
                                    @onclick="() => IrASlide(idx)"></button>
                        }
                    </div>
                }
            </div>
        }
        @* ── Formulario para dejar testimonio (Diseño Premium) ── *@
        <div class="row mt-5">
            <div class="col-12">
                <div class="testi-form-card reveal">
                    <div class="testi-form-header text-center">
                        <i class="bi bi-pencil-square me-2"></i>Deja tu opinión
                    </div>
                    <div class="testi-form-body">

                        @if (_mensajeEnvio is not null)
                        {
                            <div class="py-3 px-3 mb-4 text-center"
                                 style="border-radius: var(--radius-md);
                                            background: @(_errorEnvio ? "rgba(255, 193, 7, 0.1)" : "rgba(32, 201, 151, 0.1)");
                                            border: 1px solid @(_errorEnvio ? "rgba(255, 193, 7, 0.3)" : "rgba(32, 201, 151, 0.3)");
                                            color: @(_errorEnvio ? "#ffc107" : "#20c997");
                                            font-size: 0.95rem;
                                            font-weight: 500;">
                                <i class="bi @(_errorEnvio ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
                                @_mensajeEnvio
                            </div>
                        }

                        @if (!_enviado)
                        {
                            <div class="mb-4 text-start">
                                <label class="testi-form-label">Tu nombre *</label>
                                <input class="form-control testi-input w-100" placeholder="Ej: María García"
                                       @bind="_nuevoNombre" maxlength="150" />
                            </div>

                            <div class="mb-4 text-start">
                                <label class="testi-form-label">Calificación</label>
                                <div class="testi-stars-input d-flex justify-content-start">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var estrella = i;
                                        <button type="button" class="btn btn-link p-0 text-decoration-none"
                                                @onclick="() => _nuevaCalificacion = estrella">
                                            <i class="bi @(estrella <= _nuevaCalificacion ? "bi-star-fill" : "bi-star")"></i>
                                        </button>
                                    }
                                </div>
                            </div>

                            <div class="mb-4 text-start">
                                <label class="testi-form-label">Tu comentario *</label>
                                <textarea class="form-control testi-input w-100" rows="3"
                                          placeholder="Cuéntenos su experiencia con el estudio..."
                                          @bind="_nuevoComentario" maxlength="1000"></textarea>
                            </div>

                            <button class="testi-btn-submit w-100"
                                    @onclick="EnviarTestimonio"
                                    disabled="@_enviando">
                                @if (_enviando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Publicar testimonio
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

