    private static readonly JsonSerializerOptions JsonOpts = new() { PropertyNameCaseInsensitive = true };
    private List<LamillaEscudero.Application.Models.Servicios.ServicioOfrecidoResponse>? servicios;
    private List<LamillaEscudero.Application.Models.Miembros.MiembroEstudioResponse>? miembros;
    private LamillaEscudero.Application.Models.Configuracion.ConfiguracionEstudioResponse? config;

    private Guid? openServiceId;
    private Guid? expandedMiembroId;

    private LamillaEscudero.Application.Models.Miembros.MiembroEstudioResponse? overlayMiembro;
    private List<EducacionItem> overlayEducacion = new();
    private List<TimelineItem> overlayTimeline = new();
    private string bioTab = "bio";

    // ── Testimonios ───────────────────────────────────────────
    private List<LamillaEscudero.Application.Models.Testimonios.TestimonioResponse> _testimonios = new();
    private bool _cargandoTestimonios = true;

    // Formulario Testimonios
    private string _nuevoNombre = string.Empty;
    private string _nuevoComentario = string.Empty;
    private int _nuevaCalificacion = 5;
    private bool _enviando = false;
    private bool _enviado = false;
    private string? _mensajeEnvio = null;
    private bool _errorEnvio = false;

    // Carrusel Testimonios
    private int _carruselIndex = 0;
    private bool _carruselPausado = false;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        servicios = await ServicioService.GetAllAsync();
        miembros = await MiembroService.GetAllAsync();
        config = await ConfigService.GetAsync();

        // 1. Cargar testimonios Aprobados de la Base de Datos
        try
        {
            _testimonios = await TestimonioService.GetAprobadosAsync() ?? new();
        }
        catch { _testimonios = new(); }

        // 2. FUSIONAR: Agregar los testimonios estáticos de ejemplo
        _testimonios.AddRange(new List<LamillaEscudero.Application.Models.Testimonios.TestimonioResponse>
        {
            new() {
                Id = Guid.NewGuid(),
                Nombre = "María Cárdenas",
                Comentario = "Excelente atención desde el primer momento. Resolvieron mi caso con profesionalismo y estrategia clara. Los resultados superaron mis expectativas. Los recomiendo totalmente.",
                Calificacion = 5,
                CreatedAt = DateTime.Now.AddMonths(-3) // Le ponemos una fecha simulada
            },
            new() {
                Id = Guid.NewGuid(),
                Nombre = "Roberto Vera",
                Comentario = "Gracias al equipo de Lamilla Escudero logré obtener la resolución favorable que necesitaba. Su conocimiento del derecho local fue determinante en el resultado.",
                Calificacion = 5,
                CreatedAt = DateTime.Now.AddMonths(-2)
            },
            new() {
                Id = Guid.NewGuid(),
                Nombre = "Laura Peñafiel",
                Comentario = "Claridad, honestidad y dedicación en cada etapa del proceso. Me asesoraron perfectamente en un momento muy difícil. Sin dudas, los mejores abogados de la región.",
                Calificacion = 5,
                CreatedAt = DateTime.Now.AddMonths(-1)
            }
        });

        _cargandoTestimonios = false;

        // 3. Iniciar carrusel automático
        if (_testimonios.Count > 1)
        {
            _timer = new System.Threading.Timer(_ =>
            {
                if (!_carruselPausado)
                {
                    _carruselIndex = (_carruselIndex + 1) % _testimonios.Count;
                    InvokeAsync(StateHasChanged);
                }
            }, null, 4000, 4000);
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("eval", "window._revealInit && window._revealInit()"); }
        catch { }
    }

    private void ToggleServicio(Guid id) => openServiceId = openServiceId == id ? null : id;
    private void ToggleMiembro(Guid id) => expandedMiembroId = expandedMiembroId == id ? null : id;
    private void AbrirOverlay(LamillaEscudero.Application.Models.Miembros.MiembroEstudioResponse m)
    {
        overlayMiembro = m;
        overlayEducacion = DeserializeList<EducacionItem>(m.EducacionJson);
        overlayTimeline = DeserializeList<TimelineItem>(m.TimelineExperienciaJson);
        bioTab = "bio";
        if (string.IsNullOrWhiteSpace(m.BiografiaLarga) && string.IsNullOrWhiteSpace(m.BiografiaCompleta))
        {
            if (overlayTimeline.Any()) bioTab = "exp";
            else if (overlayEducacion.Any()) bioTab = "edu";
        }
    }

    private void CerrarOverlay() { overlayMiembro = null; }

    private void IrASlide(int idx) => _carruselIndex = idx;
    private void PausarCarrusel() => _carruselPausado = true;
    private void ReanudarCarrusel() => _carruselPausado = false;

    private async Task EnviarTestimonio()
    {
        if (string.IsNullOrWhiteSpace(_nuevoNombre) || string.IsNullOrWhiteSpace(_nuevoComentario))
        {
            _mensajeEnvio = "Por favor completa tu nombre y comentario.";
            _errorEnvio = true;
            return;
        }

        _enviando = true;
        _mensajeEnvio = null;

        try
        {
            var request = new LamillaEscudero.Application.Models.Testimonios.TestimonioCreateRequest
            {
                Nombre = _nuevoNombre,
                Comentario = _nuevoComentario,
                Calificacion = _nuevaCalificacion
            };

            // ✅ Usamos el servicio directamente en Blazor Server
            var resultado = await TestimonioService.CreateAsync(request);

            if (resultado.Estado == "Aprobado")
            {
                _mensajeEnvio = "¡Gracias! Su testimonio ya es visible.";
                _errorEnvio = false;
                _enviado = true;
                _testimonios = await TestimonioService.GetAprobadosAsync();
                _carruselIndex = _testimonios.Count - 1; // Ir al nuevo
            }
            else
            {
                _mensajeEnvio = "¡Gracias! Su testimonio está en revisión y será publicado pronto.";
                _errorEnvio = false;
                _enviado = true;
            }
        }
        catch (InvalidOperationException ex)
        {
            _mensajeEnvio = ex.Message;
            _errorEnvio = true;
        }
        catch
        {
            _mensajeEnvio = "No se pudo enviar el testimonio. Intenta de nuevo.";
            _errorEnvio = true;
        }

        _enviando = false;
    }

    public void Dispose() => _timer?.Dispose();

    private static List<T> DeserializeList<T>(string? json) where T : new()
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try { return JsonSerializer.Deserialize<List<T>>(json, JsonOpts) ?? new(); }
        catch { return new(); }
    }

    private static string GetInitials(string nombre)
    {
        var p = (nombre ?? "?").Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length >= 2 ? $"{p[0][0]}{p[1][0]}" : p.Length == 1 ? $"{p[0][0]}" : "?";
    }

