                <div class="stat-item stat-item-v3">
                    <div class="stat-item-line"></div>
                    <span class="stat-num">+500</span>
                    <span class="stat-label">Causas atendidas</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item stat-item-v3">
