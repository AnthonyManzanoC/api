@* ════════════════════════════════════════════════════════════════
   ESTILOS FUSIÓN
   ════════════════════════════════════════════════════════════════ *@
<style>

    /* ══ SCROLL REVEAL (IntersectionObserver) ════════════════════════ */
    .reveal {
        opacity: 0;
        transform: translateY(38px);
        transition: opacity .72s ease, transform .72s ease;
    }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

    /* ══ HERO ════════════════════════════════════════════════════════ */
    .hero-v2 {
        position: relative;
        overflow: hidden;
    }

    /* Patrón geométrico flotante (del modelo HTML) */
    .hero-geo-pattern {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image: url("data:image/svg+xml,%3Csvg width='70' height='70' viewBox='0 0 70 70' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M35 2L68 35L35 68L2 35Z' fill='none' stroke='%23B8963E' stroke-opacity='0.045' stroke-width='1'/%3E%3C/svg%3E");
        animation: geoFloat 28s infinite linear;
    }

    @@keyframes geoFloat {
        0% {
            transform: translateY(0) rotate(0deg);
        }

        100% {
            transform: translateY(-70px) rotate(360deg);
        }
    }

    .hero-bg-pattern {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image: radial-gradient(circle at 80% 20%, rgba(184,150,62,.07) 0%, transparent 50%), radial-gradient(circle at 15% 75%, rgba(11,31,58,.06) 0%, transparent 50%);
    }

    /* Badge pulso — ubicación (del modelo HTML) */
    .hero-pulse-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(184,150,62,.1);
        border: 1px solid var(--gold);
        padding: .5rem 1.25rem;
        border-radius: 50px;
        color: var(--gold);
        font-size: .8rem;
        font-weight: 600;
        margin-bottom: 1.25rem;
        animation: pulseBadge 2.8s infinite;
    }

    @@keyframes pulseBadge {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(184,150,62,.35);
        }

        50% {
            box-shadow: 0 0 0 13px rgba(184,150,62,0);
        }
    }

    .hero-eyebrow-wrap {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
    }

    .hero-eyebrow-line {
        width: 36px;
        height: 2px;
        background: var(--gold);
        flex-shrink: 0;
    }

    .hero-eyebrow {
        margin: 0;
    }

    .hero-title em {
        font-style: italic;
        background: linear-gradient(120deg, var(--navy), var(--gold));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-stats-bar {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--light-gray);
    }

    .hero-stat {
        display: flex;
        flex-direction: column;
    }

        .hero-stat strong {
            font-family: var(--font-display);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--navy);
        }

        .hero-stat span {
            font-size: .72rem;
            color: var(--silver);
            letter-spacing: .05em;
            text-transform: uppercase;
        }

    .hero-stat-div {
        width: 1px;
        height: 28px;
        background: var(--light-gray);
    }

    .btn-hero-primary {
        position: relative;
        overflow: hidden;
        display: inline-flex;
        align-items: center;
        background: var(--navy);
        color: white;
        padding: .85rem 1.75rem;
        border-radius: var(--radius-md);
        font-size: .9rem;
        font-weight: 500;
        transition: transform 100ms, box-shadow var(--transition);
        box-shadow: 0 4px 18px rgba(11,31,58,.28);
    }

        .btn-hero-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 28px rgba(11,31,58,.35);
            color: white;
        }

    .btn-hero-glow {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, transparent 30%, rgba(184,150,62,.22));
        opacity: 0;
        transition: opacity var(--transition);
    }

    .btn-hero-primary:hover .btn-hero-glow {
        opacity: 1;
    }

    .btn-hero-secondary {
        display: inline-flex;
        align-items: center;
        color: var(--navy);
        border: 1.5px solid var(--light-gray);
        padding: .85rem 1.75rem;
        border-radius: var(--radius-md);
        font-size: .9rem;
        font-weight: 500;
        transition: all var(--transition);
    }

        .btn-hero-secondary:hover {
            border-color: var(--navy);
            background: var(--cream);
            color: var(--navy);
        }

    /* Contact card */
    .hcc-accent {
        height: 3px;
        background: linear-gradient(90deg, var(--gold), var(--gold-light));
        margin: -1.75rem -1.75rem 1.5rem;
        border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    }

    .hcc-item-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--gold-pale);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: var(--gold);
        font-size: .82rem;
        transition: background var(--transition);
    }

    .hcc-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        font-size: .875rem;
        color: var(--charcoal);
        padding: .6rem .5rem;
        border-left: 2px solid transparent;
        transition: all var(--transition);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    }
        /* translateX al hover (del modelo HTML) */
        .hcc-item:hover {
            border-left-color: var(--gold);
            background: rgba(184,150,62,.05);
            transform: translateX(5px);
        }

            .hcc-item:hover .hcc-item-icon {
                background: var(--gold);
                color: white;
            }

    .hcc-free-badge {
        display: flex;
        align-items: center;
        background: rgba(22,163,74,.08);
        border: 1px solid rgba(22,163,74,.22);
        color: #166534;
        border-radius: var(--radius-sm);
        padding: .5rem .875rem;
        font-size: .78rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    /* Scroll indicator bouncing (del modelo HTML) */
    .hero-scroll-indicator {
        position: absolute;
        bottom: 1.75rem;
        left: 50%;
        transform: translateX(-50%);
        color: var(--gold);
        font-size: 1.3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: 1.5px solid rgba(184,150,62,.45);
        border-radius: 50%;
        background: rgba(184,150,62,.07);
        backdrop-filter: blur(4px);
        transition: all var(--transition);
        animation: scrollBounce 2.4s infinite;
        text-decoration: none;
        z-index: 10;
    }

        .hero-scroll-indicator:hover {
            background: var(--gold);
            color: white;
            border-color: var(--gold);
            animation-play-state: paused;
        }

    @@keyframes scrollBounce {
        0%, 20%, 50%, 80%, 100% {
            transform: translateX(-50%) translateY(0);
        }

        40% {
            transform: translateX(-50%) translateY(-10px);
        }

        60% {
            transform: translateX(-50%) translateY(-5px);
        }
    }

    /* ══ PRACTICE V2 ════════════════════════════════════════════════ */
    .section-title-line {
        width: 48px;
        height: 3px;
        background: linear-gradient(90deg, var(--gold), var(--gold-light));
        border-radius: 2px;
        margin: 1rem auto 0;
    }

    .practice-card-v2 {
        position: relative;
        overflow: hidden;
    }
        /* Shimmer sweep (del modelo HTML) */
        .practice-card-v2::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(184,150,62,.09), transparent);
            transition: left .55s ease;
            z-index: 0;
        }

        .practice-card-v2:hover::before {
            left: 100%;
        }
        /* Top border gold */
        .practice-card-v2::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            opacity: 0;
            transition: opacity var(--transition);
            z-index: 1;
        }

        .practice-card-v2:hover::after {
            opacity: 1;
        }

        .practice-card-v2 .practice-card-inner {
            position: relative;
            z-index: 1;
        }

    .practice-icon-wrap {
        width: 54px;
        height: 54px;
        border-radius: var(--radius-md);
        background: linear-gradient(135deg, rgba(11,31,58,.05), rgba(184,150,62,.12));
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        transition: background var(--transition), transform var(--transition);
    }

    .practice-card-v2:hover .practice-icon-wrap {
        background: linear-gradient(135deg, var(--navy), var(--navy-mid));
        transform: scale(1.08);
    }

    .practice-card-v2:hover .practice-icon {
        color: var(--gold-light);
    }

    .practice-card-featured .practice-icon-wrap {
        background: rgba(184,150,62,.15);
    }

    .btn-outline-hero-v2 {
        border: 1.5px solid var(--navy) !important;
        transition: all var(--transition);
    }

        .btn-outline-hero-v2:hover {
            background: var(--navy) !important;
            color: white !important;
        }

    /* ══ WHY SECTION ════════════════════════════════════════════════ */
    .why-section {
        padding: 6rem 0;
        background: var(--white);
    }

    .why-grid {
