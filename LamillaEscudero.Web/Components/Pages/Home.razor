@* ════════════════════════════════════════════════════════════════
   EQUIPO
   ════════════════════════════════════════════════════════════════ *@
@if (miembros is not null && miembros.Any())
{
    <section class="team-section team-v2">
        <div class="container">
            <div class="section-header reveal">
                <span class="section-eyebrow">Las personas detrás del estudio</span>
                <h2 class="section-title">Nuestro equipo</h2>
                <div class="section-title-line"></div>
                <p class="section-subtitle">Abogados comprometidos, especializados y con vocación de servicio.</p>
            </div>
            <div class="team-grid team-grid-v2">
                @foreach (var m in miembros)
                {
                    var isExpanded = expandedMiembroId == m.Id;
                    var tImgSrc = !string.IsNullOrWhiteSpace(m.PhotoData) ? m.PhotoData
                    : !string.IsNullOrWhiteSpace(m.FotoUrl) ? m.FotoUrl : null;
                    <div class="team-card team-card-v2 @(isExpanded ? "team-card-expanded" : "") reveal"
                         @onclick="() => ToggleMiembro(m.Id)">
                        <div class="team-avatar team-avatar-v2">
                            @if (tImgSrc is not null)
                            {
                                <img src="@tImgSrc" alt="@m.Nombres" class="team-photo" />
                            }
                            else
                            {

                                <div class="team-initials">@GetInitials(m.Nombres)</div>
                            }
                            <div class="team-avatar-ring"></div>
                        </div>
                        <h3 class="team-name">@m.Nombres</h3>
                        <p class="team-cargo">@m.Cargo</p>
                        @if (!string.IsNullOrWhiteSpace(m.BiografiaBreve))
                        {
                            <p class="team-bio-breve">@m.BiografiaBreve</p>
                        }
                        @if (isExpanded)
                        {
                            <div class="team-bio-full team-bio-full-v2">
                                <div class="team-bio-divider"></div>
                                @if (!string.IsNullOrWhiteSpace(m.FraseDestacada))
                                {
                                    <p class="team-bio-frase">
                                        <i class="bi bi-quote me-1" style="color:var(--gold);"></i>@m.FraseDestacada
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(m.BiografiaCompleta))
                                {
                                    <p class="team-bio-text">@m.BiografiaCompleta</p>
                                }
                                <div class="team-bio-actions">
                                    @if (!string.IsNullOrWhiteSpace(m.LinkedIn))
                                    {
                                        <a href="@m.LinkedIn" target="_blank" class="team-linkedin" @onclick:stopPropagation>
                                            <i class="bi bi-linkedin me-1"></i>LinkedIn
                                        </a>
                                    }
                                    <button class="team-btn-overlay" @onclick="() => AbrirOverlay(m)" @onclick:stopPropagation>
                                        <i class="bi bi-person-badge me-1"></i>Ver perfil completo
                                    </button>
                                </div>
                            </div>
                        }
                        <span class="team-expand-hint">
                            <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </span>
                    </div>
                }
            </div>
        </div>
    </section>
}

