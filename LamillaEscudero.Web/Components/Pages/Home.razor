    .why-feature:hover .why-feature-bg-num {
        opacity: .14;
    }

    .why-feature-body {
        position: relative;
        z-index: 1;
        margin-top: 1.5rem;
    }

    .why-feature-icon {
        width: 52px;
        height: 52px;
