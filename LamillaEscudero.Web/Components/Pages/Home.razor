@page "/"
@inject LamillaEscudero.Application.Abstractions.IServicioOfrecidoService ServicioService
@inject LamillaEscudero.Application.Abstractions.IMiembroEstudioService MiembroService
@inject LamillaEscudero.Application.Abstractions.IConfiguracionEstudioService ConfigService
@inject Microsoft.JSInterop.IJSRuntime JS
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>Inicio — Lamilla Escudero &amp; Asociados</PageTitle>

@* ════════════════════════════════════════════════════════════════
   OVERLAY — PERFIL COMPLETO DEL ABOGADO
   ════════════════════════════════════════════════════════════════ *@
@if (overlayMiembro is not null)
{
    <div class="bio-overlay" @onclick="CerrarOverlay">
        <div class="bio-panel" @onclick:stopPropagation>
            <button class="bio-close" @onclick="CerrarOverlay"><i class="bi bi-x-lg"></i></button>
            <div class="bio-left">
                <div class="bio-photo-wrap">
                    @{
                        var imgSrc = !string.IsNullOrWhiteSpace(overlayMiembro.PhotoData)
                        ? overlayMiembro.PhotoData
                        : !string.IsNullOrWhiteSpace(overlayMiembro.FotoUrl)
                        ? overlayMiembro.FotoUrl : null;
                    }
                    @if (imgSrc is not null)
                    {
                        <img src="@imgSrc" alt="@overlayMiembro.Nombres" class="bio-photo" />
                    }
                    else
                    {

                        <div class="bio-initials">@GetInitials(overlayMiembro.Nombres)</div>
                    }
                    <div class="bio-photo-ring"></div>
                </div>
                <h2 class="bio-name">@overlayMiembro.Nombres</h2>
                <p class="bio-cargo">@overlayMiembro.Cargo</p>
                @if (!string.IsNullOrWhiteSpace(overlayMiembro.FraseDestacada))
                {
                    <blockquote class="bio-frase">
                        <i class="bi bi-quote bio-quote-icon"></i>@overlayMiembro.FraseDestacada
                    </blockquote>
                }
                <div class="bio-contact-links">
                    @if (!string.IsNullOrWhiteSpace(overlayMiembro.Email))
                    {
                        <a href="mailto:@overlayMiembro.Email" class="bio-contact-link">
                            <i class="bi bi-envelope-fill"></i><span>@overlayMiembro.Email</span>
                        </a>
                    }
                    @if (!string.IsNullOrWhiteSpace(overlayMiembro.LinkedIn))
                    {
                        <a href="@overlayMiembro.LinkedIn" target="_blank" class="bio-contact-link bio-linkedin">
                            <i class="bi bi-linkedin"></i><span>LinkedIn</span>
                        </a>
                    }
                </div>
            </div>
            <div class="bio-right">
                <div class="bio-tabs">
                    <button class="bio-tab @(bioTab == "bio" ? "active" : "")" @onclick='() => bioTab = "bio"'>
                        <i class="bi bi-person-lines-fill me-1"></i>Biografía
                    </button>
                    @if (overlayTimeline.Any())
                    {
                        <button class="bio-tab @(bioTab == "exp" ? "active" : "")" @onclick='() => bioTab = "exp"'>
                            <i class="bi bi-briefcase-fill me-1"></i>Trayectoria
                        </button>
                    }
                    @if (overlayEducacion.Any())
                    {
                        <button class="bio-tab @(bioTab == "edu" ? "active" : "")" @onclick='() => bioTab = "edu"'>
                            <i class="bi bi-mortarboard-fill me-1"></i>Formación
                        </button>
                    }
                </div>
                @if (bioTab == "bio")
                {
                    <div class="bio-content-section">
                        @if (!string.IsNullOrWhiteSpace(overlayMiembro.BiografiaLarga))
                        {
                            <p class="bio-text">@overlayMiembro.BiografiaLarga</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(overlayMiembro.BiografiaCompleta))
                        {

                            <p class="bio-text">@overlayMiembro.BiografiaCompleta</p>
                        }
                        else
                        {

                            <p class="bio-text bio-text-empty">Perfil en preparación.</p>
                        }
                    </div>
                }
                @if (bioTab == "exp")
                {
                    <div class="bio-timeline">
                        @foreach (var item in overlayTimeline)
                        {
                            <div class="bio-tl-item">
                                <div class="bio-tl-dot"></div>
                                <div class="bio-tl-year">@item.Anio</div>
                                <div class="bio-tl-body">
                                    <p class="bio-tl-titulo">@item.Titulo</p>
                                    @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                    {
                                        <p class="bio-tl-desc">@item.Descripcion</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                @if (bioTab == "edu")
                {
                    <div class="bio-educacion">
                        @foreach (var item in overlayEducacion)
                        {
                            <div class="bio-edu-item">
                                <div class="bio-edu-icon"><i class="bi bi-award-fill"></i></div>
                                <div class="bio-edu-body">
                                    <p class="bio-edu-titulo">@item.Titulo</p>
                                    @if (!string.IsNullOrWhiteSpace(item.Institucion))
                                    {
                                        <p class="bio-edu-inst">@item.Institucion</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.Anio))
                                    {
                                        <p class="bio-edu-anio">@item.Anio</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ════════════════════════════════════════════════════════════════
   HERO — patrón flotante + badge pulso + scroll indicator
   ════════════════════════════════════════════════════════════════ *@
<section class="hero-section hero-v2" id="inicio">
    <div class="hero-geo-pattern" aria-hidden="true"></div>
    <div class="hero-bg-pattern"></div>
    <div class="container" style="position:relative;z-index:2;">
        <div class="hero-inner">
            <div class="hero-copy">
                @if (config is not null && (!string.IsNullOrWhiteSpace(config.PhotoUrl) || !string.IsNullOrWhiteSpace(config.LogoUrl)))
                {
                    <div class="home-brand-logo animate-fade-in">
                        <img src="@(!string.IsNullOrWhiteSpace(config.PhotoUrl) ? config.PhotoUrl : config.LogoUrl)"
                             alt="@config.NombreEstudio" />
                    </div>
                }
                <div class="hero-pulse-badge">
                    <i class="bi bi-geo-alt-fill me-1"></i>Babahoyo · Los Ríos · Ecuador
                </div>
                <div class="hero-eyebrow-wrap">
                    <span class="hero-eyebrow-line"></span>
                    <p class="hero-eyebrow">Estudio Jurídico de excelencia</p>
                </div>
                <h1 class="hero-title">
                    Solidez jurídica,<br /><em>trato humano.</em>
                </h1>
                <p class="hero-subtitle">
                    Más de una década acompañando a nuestros clientes en las decisiones legales
                    más importantes de sus vidas. Estrategia clara, resultados concretos.
                </p>
                <div class="hero-actions">
                    <a href="/contacto" class="btn-hero-primary">
                        <span class="btn-hero-glow"></span>
                        <i class="bi bi-chat-text me-2"></i>Consulta gratuita
                    </a>
                    <a href="/servicios" class="btn-hero-secondary">
                        <i class="bi bi-grid me-2"></i>Nuestros servicios
                    </a>
                </div>
                <div class="hero-stats-bar">
                    <div class="hero-stat"><strong>+15</strong><span>Años</span></div>
                    <div class="hero-stat-div"></div>
                    <div class="hero-stat"><strong>+500</strong><span>Casos</span></div>
                    <div class="hero-stat-div"></div>
                    <div class="hero-stat"><strong>100%</strong><span>Compromiso</span></div>
                </div>
            </div>
            <div class="hero-contact-card">
                <div class="hcc-accent"></div>
                <div class="hcc-header">
                    <span class="hcc-tag"><i class="bi bi-telephone-inbound me-1"></i>Contacto directo</span>
                </div>
                <div class="hcc-items">
                    @if (config is not null)
                    {
                        @if (!string.IsNullOrWhiteSpace(config.TelefonoContacto))
                        {
                            <div class="hcc-item">
                                <div class="hcc-item-icon"><i class="bi bi-telephone-fill"></i></div>
                                <span>@config.TelefonoContacto</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(config.EmailContacto))
                        {
                            <div class="hcc-item">
                                <div class="hcc-item-icon"><i class="bi bi-envelope-fill"></i></div>
                                <span>@config.EmailContacto</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(config.Direccion))
                        {
                            <div class="hcc-item">
                                <div class="hcc-item-icon"><i class="bi bi-geo-alt-fill"></i></div>
                                <span>@config.Direccion</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="hcc-item">
                            <div class="hcc-item-icon"><i class="bi bi-hourglass"></i></div>
                            <span>Cargando...</span>
                        </div>
                    }
                </div>
                <div class="hcc-free-badge">
                    <i class="bi bi-check-circle-fill me-1"></i>Primera consulta sin costo
                </div>
                <a href="/contacto" class="hcc-cta">
                    <i class="bi bi-send me-2"></i>Enviar consulta
                </a>
            </div>
        </div>
    </div>
    <a href="#servicios" class="hero-scroll-indicator" aria-label="Ir a servicios">
        <i class="bi bi-chevron-down"></i>
    </a>
</section>

@* ════════════════════════════════════════════════════════════════
   ÁREAS DE PRÁCTICA
   ════════════════════════════════════════════════════════════════ *@
<section class="practice-section practice-v2" id="servicios">
    <div class="container">
        <div class="section-header reveal">
            <span class="section-eyebrow">Especialidades</span>
            <h2 class="section-title">Áreas de práctica</h2>
            <div class="section-title-line"></div>
        </div>
        @if (servicios is null)
        {
            <div class="text-center py-5">
                <div class="spinner-border" style="color:var(--gold);width:1.5rem;height:1.5rem;"></div>
            </div>
        }
        else if (!servicios.Any())
        {
            <div class="practice-grid practice-grid-v2">
                @foreach (var s in staticServices)
                {
                    <div class="practice-card @(s.Featured ? "practice-card-featured" : "") practice-card-v2 reveal">
                        <div class="practice-card-inner">
                            <div class="practice-icon-wrap">
                                <i class="bi @s.Icono practice-icon"></i>
                            </div>
                            <h3 class="practice-name">@s.Titulo</h3>
                            <p class="practice-desc">@s.Desc</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="practice-grid practice-grid-v2">
                @foreach (var (s, idx) in servicios.Select((x, i) => (x, i)))
                {
                    var isOpen = openServiceId == s.Id;
                    <div class="practice-card @(idx == 1 ? "practice-card-featured" : "") practice-card-interactive practice-card-v2 reveal"
                         @onclick="() => ToggleServicio(s.Id)">
                        <div class="practice-card-inner">
                            <div class="practice-icon-wrap">
                                <i class="bi @(s.Icono ?? "bi-briefcase") practice-icon"></i>
                            </div>
                            <h3 class="practice-name">@s.Titulo</h3>
                            <p class="practice-desc">@s.DescripcionCorta</p>
                            @if (!string.IsNullOrWhiteSpace(s.Detalles))
                            {
                                <div class="practice-expand @(isOpen ? "open" : "")">
                                    <div class="practice-expand-body">@s.Detalles</div>
                                </div>
                                <span class="practice-toggle">
                                    <i class="bi @(isOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        <div class="text-center mt-5 reveal">
            <a href="/servicios" class="btn-outline-hero btn-outline-hero-v2">
                <i class="bi bi-arrow-right me-2"></i>Ver todos los servicios
            </a>
        </div>
    </div>
</section>

