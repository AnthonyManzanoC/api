    /* ══ LOGO HERO ══════════════════════════════════════════════════ */
    .home-brand-logo {
        display: inline-block;
        margin-bottom: 1.5rem;
        padding: .75rem 1.25rem;
        background: var(--white);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(11,31,58,.08);
        border: 1px solid rgba(184,150,62,.15);
    }

        .home-brand-logo img {
            max-height: 90px;
            max-width: 100%;
            object-fit: contain;
        }

    .animate-fade-in {
        animation: fadeInLogo .8s ease-out;
    }

    @@keyframes fadeInLogo {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ══ BIO OVERLAY ════════════════════════════════════════════════ */
    .bio-overlay {
        position: fixed;
        inset: 0;
        z-index: 9900;
        background: rgba(7,22,41,.78);
        backdrop-filter: blur(12px) saturate(1.4);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        animation: overlayFadeIn 240ms ease;
    }

    @@keyframes overlayFadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .bio-panel {
        position: relative;
        display: grid;
        grid-template-columns: 280px 1fr;
        width: 100%;
        max-width: 900px;
        max-height: 88vh;
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: 0 32px 80px rgba(11,31,58,.4);
        animation: panelSlideUp 280ms cubic-bezier(.4,0,.2,1);
    }

    @@keyframes panelSlideUp {
        from {
            opacity: 0;
            transform: translateY(24px) scale(.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

