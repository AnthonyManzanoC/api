        margin-bottom: 1.5rem;
        display: inline-block;
    }

    .bio-photo {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--gold);
        box-shadow: 0 8px 32px rgba(0,0,0,.4);
    }

    .bio-initials {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(184,150,62,.25), rgba(184,150,62,.1));
        border: 3px solid var(--gold);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-size: 2.8rem;
        font-weight: 700;
        color: var(--gold-light);
