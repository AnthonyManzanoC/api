        border: 2px solid rgba(184,150,62,.35);
        animation: ringPulse 3s infinite;
    }

    @@keyframes ringPulse {
        0%, 100% {
            transform: scale(1);
            opacity: .6;
        }

        50% {
            transform: scale(1.05);
            opacity: .3;
        }
