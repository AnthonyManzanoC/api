@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="admin-shell">

    <AdminNavMenu />

    <div class="admin-main">
        <header class="admin-topbar">
            <div class="topbar-left">
                <button class="topbar-menu-btn" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <nav aria-label="breadcrumb" class="topbar-breadcrumb">
                    <span class="breadcrumb-current">@GetPageTitle()</span>
                </nav>
            </div>
            <div class="topbar-right">
                <span class="topbar-date">@DateTime.Now.ToString("dd 'de' MMMM, yyyy", new System.Globalization.CultureInfo("es-EC"))</span>
                <a href="/logout" class="topbar-logout-btn">
                    <i class="bi bi-box-arrow-right me-1"></i>
                    <span>Salir</span>
                </a>
            </div>
        </header>

        <div class="admin-content">
            @* AQUÍ BLAZOR DIBUJA LAS PÁGINAS *@
            @Body
        </div>
    </div>

    <LamillaEscudero.Web.Components.Pages.ChatbotAdmin />

</div>

<script>
    // Toggle sidebar en móvil
    document.addEventListener('DOMContentLoaded', function () {
        var btn = document.getElementById('sidebarToggle');
        var sidebar = document.querySelector('.admin-sidebar');
        if (btn && sidebar) {
            btn.addEventListener('click', function () {
                sidebar.classList.toggle('sidebar-open');
            });
        }
    });
</script>

@code {
    private string GetPageTitle()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.ToLower();
        return path switch
        {
            "/admin" => "Dashboard",
            "/admin/clientes" => "Clientes",
            "/admin/causas" => "Causas",
            "/admin/eventos" => "Eventos Procesales",
            "/admin/plazos" => "Plazos",
            "/admin/documentos" => "Documentos",
            "/admin/notificaciones" => "Notificaciones",
            "/admin/consultas" => "Consultas Web",
            "/admin/configuracion" => "Configuración",
            // Agregamos los títulos para las nuevas páginas:
            "/admin/cuentas" => "Centro de Cuentas",
            "/admin/cms/miembros" => "Equipo del Estudio",
            "/admin/cms/servicios" => "Servicios Ofrecidos",
            _ => "Panel Administrativo"
        };
    }
}