    <script>
        window.copyAndOpenSatje = function (numeroProceso) {
            // 1. Copiar al portapapeles
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(numeroProceso).catch(function () {
                    // Fallback para navegadores sin soporte
                    legacyCopy(numeroProceso);
                });
            } else {
                legacyCopy(numeroProceso);
            }

            // 2. Abrir e-SATJE en nueva pestaña
            window.open(
                'https://procesosjudiciales.funcionjudicial.gob.ec/busqueda-filtros',
                '_blank',
                'noopener,noreferrer'
            );
        };

        function legacyCopy(text) {
            var el = document.createElement('textarea');
            el.value = text;
            el.style.position = 'fixed';
            el.style.opacity = '0';
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
        }
    </script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js');
        }
    </script>
</body>

